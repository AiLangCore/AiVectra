            Field(key="kp_7") { Lit(value="7") }
            Field(key="kp_8") { Lit(value="8") }
            Field(key="kp_9") { Lit(value="9") }
            Field(key="space") { Lit(value=" ") }
            Field(key=" ") { Lit(value=" ") }
            Field(key="tab") { Lit(value="\t") }
            Field(key="Tab") { Lit(value="\t") }
            Field(key="\t") { Lit(value="\t") }
            Field(key=".") { Lit(value=".") }
            Field(key=",") { Lit(value=",") }
            Field(key="-") { Lit(value="-") }
            Field(key="_") { Lit(value="_") }
