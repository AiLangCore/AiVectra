Program {
  Import(path="../../../.tools/std/core.aos")

  Let(name=version) {
    Fn(params=_) {
      Block { Return { Lit(value="0.0.1") } }
    }
  }

  Let(name=library) {
    Fn(params=_) {
      Block { Return { Lit(value="AiVectra") } }
    }
  }

  Let(name=rect) {
    Fn(params=windowHandle) {
      Block {
        Let(name=sizeNode) { Call(target=sys.ui.getWindowSize) { Var(name=windowHandle) } }
        Let(name=wRaw) { Call(target=attrInt) { Var(name=sizeNode) Lit(value="width") Lit(value=0) } }
        Let(name=hRaw) { Call(target=attrInt) { Var(name=sizeNode) Lit(value="height") Lit(value=0) } }
        Let(name=w) { Call(target=stabilizeSize) { Var(name=wRaw) Lit(value=640) Lit(value=640) } }
        Let(name=h) { Call(target=stabilizeSize) { Var(name=hRaw) Lit(value=360) Lit(value=360) } }
        Let(name=panelX) { Lit(value=20) }
        Let(name=panelY) { Lit(value=20) }
        Let(name=panelWRaw) { Call(target=sub) { Var(name=w) Lit(value=40) } }
        Let(name=panelHRaw) { Call(target=sub) { Var(name=h) Lit(value=40) } }
        Let(name=panelW) { Call(target=stabilizeSize) { Var(name=panelWRaw) Lit(value=600) Lit(value=1) } }
        Let(name=panelH) { Call(target=stabilizeSize) { Var(name=panelHRaw) Lit(value=320) Lit(value=1) } }
        Call(target=sys.ui.drawRect) {
          Var(name=windowHandle)
          Var(name=panelX)
          Var(name=panelY)
          Var(name=panelW)
          Var(name=panelH)
          Lit(value="#1e293b")
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=circle) {
    Fn(params=spec) {
      Block {
        Return {
          StrConcat {
            Lit(value="Circle(")
            StrConcat { ToString { Var(name=spec) } Lit(value=")") }
          }
        }
      }
    }
  }

  Let(name=text) {
    Fn(params=windowHandle,value) {
      Block {
        Let(name=sizeNode) { Call(target=sys.ui.getWindowSize) { Var(name=windowHandle) } }
        Let(name=wRaw) { Call(target=attrInt) { Var(name=sizeNode) Lit(value="width") Lit(value=0) } }
        Let(name=hRaw) { Call(target=attrInt) { Var(name=sizeNode) Lit(value="height") Lit(value=0) } }
        Let(name=w) { Call(target=stabilizeSize) { Var(name=wRaw) Lit(value=640) Lit(value=640) } }
        Let(name=h) { Call(target=stabilizeSize) { Var(name=hRaw) Lit(value=360) Lit(value=360) } }
        Let(name=panelX) { Lit(value=20) }
        Let(name=panelY) { Lit(value=20) }
        Let(name=panelWRaw) { Call(target=sub) { Var(name=w) Lit(value=40) } }
        Let(name=panelHRaw) { Call(target=sub) { Var(name=h) Lit(value=40) } }
        Let(name=panelW) { Call(target=stabilizeSize) { Var(name=panelWRaw) Lit(value=600) Lit(value=1) } }
        Let(name=panelH) { Call(target=stabilizeSize) { Var(name=panelHRaw) Lit(value=320) Lit(value=1) } }
        Let(name=fontCandidate) { Call(target=divFloor) { Var(name=panelH) Lit(value=9) Lit(value=0) } }
        Let(name=fontSize) {
          If {
            Call(target=intLt) { Var(name=fontCandidate) Lit(value=18) }
            Block { Lit(value=18) }
            Block {
              If {
                Call(target=intLt) { Lit(value=34) Var(name=fontCandidate) }
                Block { Lit(value=34) }
                Block { Var(name=fontCandidate) }
              }
            }
          }
        }
        Let(name=charWidth) { Add { Call(target=halfFloor) { Var(name=fontSize) Lit(value=0) } Lit(value=1) } }
        Let(name=textWidth) { Call(target=mul) { Var(name=charWidth) Call(target=textLen) { Var(name=value) } Lit(value=0) } }
        Let(name=xOffsetRaw) { Call(target=sub) { Var(name=panelW) Var(name=textWidth) } }
        Let(name=xOffset) {
          If {
            Call(target=intLt) { Var(name=xOffsetRaw) Lit(value=0) }
            Block { Lit(value=0) }
            Block { Call(target=halfFloor) { Var(name=xOffsetRaw) Lit(value=0) } }
          }
        }
        Let(name=textX) { Add { Var(name=panelX) Var(name=xOffset) } }
        Let(name=textY) { Add { Var(name=panelY) Call(target=halfFloor) { Add { Var(name=panelH) Var(name=fontSize) } Lit(value=0) } } }
        Call(target=sys.ui.drawText) {
          Var(name=windowHandle)
          Var(name=textX)
          Var(name=textY)
          Var(name=value)
          Lit(value="#ffffff")
          Var(name=fontSize)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=label) {
    Fn(params=windowHandle,value) {
      Block {
        Return { Call(target=text) { Var(name=windowHandle) Var(name=value) } }
      }
    }
  }

  Let(name=window) {
    Fn(params=title) {
      Block {
        Return {
          Call(target=sys.ui.createWindow) { Var(name=title) Lit(value=640) Lit(value=360) }
        }
      }
    }
  }

  Let(name=appBuild) {
    Fn(params=title,width,height) {
      Block {
        Return { Call(target=sys.ui.createWindow) { Var(name=title) Var(name=width) Var(name=height) } }
      }
    }
  }

  Let(name=frameBegin) {
    Fn(params=windowHandle) {
      Block {
        Call(target=sys.ui.beginFrame) { Var(name=windowHandle) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=framePresent) {
    Fn(params=windowHandle) {
      Block {
        Call(target=sys.ui.endFrame) { Var(name=windowHandle) }
        Call(target=sys.ui.present) { Var(name=windowHandle) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=frameRect) {
    Fn(params=windowHandle,x,y,w,h,fill) {
      Block {
        Call(target=sys.ui.drawRect) { Var(name=windowHandle) Var(name=x) Var(name=y) Var(name=w) Var(name=h) Var(name=fill) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=frameText) {
    Fn(params=windowHandle,x,y,value,fill,fontSize) {
      Block {
        Call(target=sys.ui.drawText) { Var(name=windowHandle) Var(name=x) Var(name=y) Var(name=value) Var(name=fill) Var(name=fontSize) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=frameLine) {
    Fn(params=windowHandle,x1,y1,x2,y2,fill,strokeWidth) {
      Block {
        Call(target=sys.ui.drawLine) { Var(name=windowHandle) Var(name=x1) Var(name=y1) Var(name=x2) Var(name=y2) Var(name=fill) Var(name=strokeWidth) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=frameEllipse) {
    Fn(params=windowHandle,x,y,w,h,fill) {
      Block {
        Call(target=sys.ui.drawEllipse) { Var(name=windowHandle) Var(name=x) Var(name=y) Var(name=w) Var(name=h) Var(name=fill) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=framePath) {
    Fn(params=windowHandle,path,fill,strokeWidth) {
      Block {
        Call(target=sys.ui.drawPath) { Var(name=windowHandle) Var(name=path) Var(name=fill) Var(name=strokeWidth) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=frameImage) {
    Fn(params=windowHandle,x,y,w,h,rgbaBase64) {
      Block {
        Call(target=sys.ui.drawImage) { Var(name=windowHandle) Var(name=x) Var(name=y) Var(name=w) Var(name=h) Var(name=rgbaBase64) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=uiPollEvent) {
    Fn(params=windowHandle) {
      Block {
        Return { Call(target=sys.ui.pollEvent) { Var(name=windowHandle) } }
      }
    }
  }

  Let(name=sceneDefs) {
    Fn(params=_) {
      Block { Return { Call(target=nodeEmpty) { Lit(value="defs") } } }
    }
  }

  Let(name=sceneSymbolInteractiveButton) {
    Fn(params=symbolId) {
      Block {
        Let(name=base) { Call(target=nodeEmpty) { Lit(value="symbol") } }
        Let(name=withId) { Call(target=mapSet) { Var(name=base) Lit(value="id") Var(name=symbolId) } }
        Return { Call(target=mapSet) { Var(name=withId) Lit(value="kind") Lit(value="interactive-button") } }
      }
    }
  }

  Let(name=sceneDefsAdd) {
    Fn(params=defsNode,symbolNode) {
      Block { Return { AppendChild { Var(name=defsNode) Var(name=symbolNode) } } }
    }
  }

  Let(name=sceneSymbolId) {
    Fn(params=symbolNode) {
      Block { Return { Call(target=mapGetStringOr) { Var(name=symbolNode) Lit(value="id") Lit(value="") } } }
    }
  }

  Let(name=sceneSymbolKind) {
    Fn(params=symbolNode) {
      Block { Return { Call(target=mapGetStringOr) { Var(name=symbolNode) Lit(value="kind") Lit(value="") } } }
    }
  }

  Let(name=sceneDefsFindAt) {
    Fn(params=defsNode,symbolId,index) {
      Block {
        If {
          Eq { Var(name=index) ChildCount { Var(name=defsNode) } }
          Block { Return { Call(target=nodeEmpty) { Lit(value="missing-symbol") } } }
          Block {
            Let(name=symbolNode) { ChildAt { Var(name=defsNode) Var(name=index) } }
            If {
              Eq { Call(target=sceneSymbolId) { Var(name=symbolNode) } Var(name=symbolId) }
              Block { Return { Var(name=symbolNode) } }
              Block { Return { Call(target=sceneDefsFindAt) { Var(name=defsNode) Var(name=symbolId) Add { Var(name=index) Lit(value=1) } } } }
            }
          }
        }
      }
    }
  }

  Let(name=sceneDefsFind) {
    Fn(params=defsNode,symbolId) {
      Block { Return { Call(target=sceneDefsFindAt) { Var(name=defsNode) Var(name=symbolId) Lit(value=0) } } }
    }
  }

  Let(name=sceneUsePropString) {
    Fn(params=props,key,fallback) {
      Block { Return { Call(target=mapGetStringOr) { Var(name=props) Var(name=key) Var(name=fallback) } } }
    }
  }

  Let(name=sceneUsePropInt) {
    Fn(params=props,key,fallback) {
      Block { Return { Call(target=mapGetIntOr) { Var(name=props) Var(name=key) Var(name=fallback) } } }
    }
  }

  Let(name=drawSymbolSearchIcon) {
    Fn(params=handle,x,y,fill) {
      Block {
        Call(target=frameRect) { Var(name=handle) Add { Var(name=x) Lit(value=10) } Add { Var(name=y) Lit(value=9) } Lit(value=12) Lit(value=12) Var(name=fill) }
        Call(target=frameLine) { Var(name=handle) Add { Var(name=x) Lit(value=20) } Add { Var(name=y) Lit(value=20) } Add { Var(name=x) Lit(value=28) } Add { Var(name=y) Lit(value=28) } Var(name=fill) Lit(value=2) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=drawSymbolDotsIcon) {
    Fn(params=handle,x,y,fill) {
      Block {
        Call(target=frameRect) { Var(name=handle) Add { Var(name=x) Lit(value=14) } Add { Var(name=y) Lit(value=16) } Lit(value=6) Lit(value=6) Var(name=fill) }
        Call(target=frameRect) { Var(name=handle) Add { Var(name=x) Lit(value=24) } Add { Var(name=y) Lit(value=16) } Lit(value=6) Lit(value=6) Var(name=fill) }
        Call(target=frameRect) { Var(name=handle) Add { Var(name=x) Lit(value=34) } Add { Var(name=y) Lit(value=16) } Lit(value=6) Lit(value=6) Var(name=fill) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=sceneRenderInteractiveButtonUse) {
    Fn(params=handle,instanceId,x,y,props) {
      Block {
        Let(name=w) { Call(target=sceneUsePropInt) { Var(name=props) Lit(value="w") Lit(value=120) } }
        Let(name=h) { Call(target=sceneUsePropInt) { Var(name=props) Lit(value="h") Lit(value=40) } }
        Let(name=state) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="state") Lit(value="normal") } }
        Let(name=label) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="label") Lit(value="") } }
        Let(name=labelFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="labelFill") Lit(value="#ffffff") } }
        Let(name=labelSize) { Call(target=sceneUsePropInt) { Var(name=props) Lit(value="labelSize") Lit(value=16) } }
        Let(name=labelOffsetX) { Call(target=sceneUsePropInt) { Var(name=props) Lit(value="labelOffsetX") Lit(value=16) } }
        Let(name=labelOffsetY) { Call(target=sceneUsePropInt) { Var(name=props) Lit(value="labelOffsetY") Lit(value=24) } }
        Let(name=iconKind) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="iconKind") Lit(value="") } }
        Let(name=iconFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="iconFill") Lit(value="#ffffff") } }
        Let(name=normalFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="normalFill") Lit(value="#1f2937") } }
        Let(name=pressedFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="pressedFill") Lit(value="#374151") } }
        Let(name=hoverFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="hoverFill") Lit(value="#334155") } }
        Let(name=focusedFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="focusedFill") Lit(value="#1d4ed8") } }
        Let(name=disabledFill) { Call(target=sceneUsePropString) { Var(name=props) Lit(value="disabledFill") Lit(value="#475569") } }
        Call(target=interactiveVectorState) {
          Var(name=handle) Var(name=x) Var(name=y) Var(name=w) Var(name=h)
          Var(name=state)
          Lit(value="rect") Lit(value="")
          Var(name=normalFill) Var(name=pressedFill) Var(name=hoverFill) Var(name=focusedFill) Var(name=disabledFill)
        }
        If {
          Eq { Var(name=iconKind) Lit(value="search") }
          Block { Call(target=drawSymbolSearchIcon) { Var(name=handle) Var(name=x) Var(name=y) Var(name=iconFill) } }
          Block {
            If {
              Eq { Var(name=iconKind) Lit(value="dots") }
              Block { Call(target=drawSymbolDotsIcon) { Var(name=handle) Var(name=x) Var(name=y) Var(name=iconFill) } }
              Block { Lit(value=0) }
            }
          }
        }
        If {
          Eq { Var(name=label) Lit(value="") }
          Block { Lit(value=0) }
          Block { Call(target=frameText) { Var(name=handle) Add { Var(name=x) Var(name=labelOffsetX) } Add { Var(name=y) Var(name=labelOffsetY) } Var(name=label) Var(name=labelFill) Var(name=labelSize) } }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=sceneUse) {
    Fn(params=handle,defsNode,symbolId,instanceId,x,y,props) {
      Block {
        Let(name=symbolNode) { Call(target=sceneDefsFind) { Var(name=defsNode) Var(name=symbolId) } }
        Let(name=symbolKind) { Call(target=sceneSymbolKind) { Var(name=symbolNode) } }
        If {
          Eq { Var(name=symbolKind) Lit(value="interactive-button") }
          Block { Return { Call(target=sceneRenderInteractiveButtonUse) { Var(name=handle) Var(name=instanceId) Var(name=x) Var(name=y) Var(name=props) } } }
          Block { Return { Lit(value=0) } }
        }
      }
    }
  }

  Let(name=appRun) {
    Fn(params=windowHandle,model) {
      Block {
        Return { Call(target=appLoop) { Var(name=windowHandle) Var(name=model) } }
      }
    }
  }

  Let(name=appRunScene) {
    Fn(params=windowHandle,model) {
      Block {
        Call(target=appRender) { Var(name=windowHandle) Var(name=model) }
        Call(target=sys.ui.waitFrame) { Var(name=windowHandle) }
        Call(target=appRender) { Var(name=windowHandle) Var(name=model) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=appStart) {
    Fn(params=args,title,width,height) {
      Block {
        Let(name=mode) { Call(target=appModeFromArgs) { Var(name=args) } }
        If {
          Eq { Var(name=mode) Lit(value="snapshot") }
          Block { Return { Lit(value=0) } }
          Block { Lit(value=0) }
        }
        Let(name=windowHandle) { Call(target=appBuild) { Var(name=title) Var(name=width) Var(name=height) } }
        Let(name=model) { Call(target=appInit) { Var(name=args) } }
        If {
          Eq { Var(name=mode) Lit(value="scene") }
          Block { Call(target=appRunScene) { Var(name=windowHandle) Var(name=model) } }
          Block { Call(target=appRun) { Var(name=windowHandle) Var(name=model) } }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugModeEvents) {
    Fn(params=mode) {
      Block {
        If {
          Eq { Var(name=mode) Lit(value="events") }
          Block { Return { Lit(value=true) } }
          Block { Return { Lit(value=false) } }
        }
      }
    }
  }

  Let(name=appLoop) {
    Fn(params=windowHandle,model) {
      Block {
        Let(name=currentModel) { Var(name=model) }
        Loop {
          Block {
            Call(target=appRender) { Var(name=windowHandle) Var(name=currentModel) }
            Call(target=sys.ui.waitFrame) { Var(name=windowHandle) }
            Let(name=sizeNode) { Call(target=sys.ui.getWindowSize) { Var(name=windowHandle) } }
            Let(name=eventWidthRaw) { Call(target=attrInt) { Var(name=sizeNode) Lit(value="width") Lit(value=0) } }
            Let(name=eventHeightRaw) { Call(target=attrInt) { Var(name=sizeNode) Lit(value="height") Lit(value=0) } }
            Let(name=evt) { Call(target=sys.ui.pollEvent) { Var(name=windowHandle) } }
            Let(name=eventType) {
              If {
                Eq { AttrCount { Var(name=evt) } Lit(value=0) }
                Block { Lit(value="none") }
                Block { Call(target=attrString) { Var(name=evt) Lit(value="type") Lit(value=0) } }
              }
            }
            Let(name=eventKey) {
              If {
                Eq { AttrCount { Var(name=evt) } Lit(value=0) }
                Block { Lit(value="") }
                Block { Call(target=attrString) { Var(name=evt) Lit(value="key") Lit(value=0) } }
              }
            }
            Let(name=eventText) {
              If {
                Eq { AttrCount { Var(name=evt) } Lit(value=0) }
                Block { Lit(value="") }
                Block { Call(target=attrString) { Var(name=evt) Lit(value="text") Lit(value=0) } }
              }
            }
            Let(name=eventX) {
              If {
                Eq { AttrCount { Var(name=evt) } Lit(value=0) }
                Block { Lit(value=0) }
                Block { Call(target=attrInt) { Var(name=evt) Lit(value="x") Lit(value=0) } }
              }
            }
            Let(name=eventY) {
              If {
                Eq { AttrCount { Var(name=evt) } Lit(value=0) }
                Block { Lit(value=0) }
                Block { Call(target=attrInt) { Var(name=evt) Lit(value="y") Lit(value=0) } }
              }
            }
            If {
              Eq { Var(name=eventType) Lit(value="closed") }
              Block { Break { } }
              Block { Lit(value=0) }
            }
            Let(name=nextModel) {
              Call(target=appUpdate) {
                Var(name=currentModel)
                Var(name=eventType)
                Var(name=eventKey)
                Var(name=eventText)
                Var(name=eventX)
                Var(name=eventY)
                Var(name=eventWidthRaw)
                Var(name=eventHeightRaw)
              }
            }
            Let(name=currentModel) { Var(name=nextModel) }
            Continue { }
          }
        }
        Return { Var(name=currentModel) }
      }
    }
  }

  Let(name=helloWindow) {
    Fn(params=_) {
      Block {
        Return { Call(target=helloNamedWindow) { Lit(value="World") } }
      }
    }
  }

  Let(name=helloNamedWindow) {
    Fn(params=name) {
      Block {
        Let(name=handle) { Call(target=window) { Lit(value="AiVectra Hello") } }
        Let(name=greeting) {
          StrConcat {
            Lit(value="Hello ")
            StrConcat { ToString { Var(name=name) } Lit(value="!") }
          }
        }
        Call(target=debugEmitSceneNode) {
          Lit(value=1)
          Lit(value=1)
          Lit(value="hello_panel")
          Lit(value="root")
          Lit(value="Rect")
          Lit(value="#1e293b")
          Lit(value="")
          Lit(value=0)
          Lit(value="")
          Lit(value="")
          Lit(value=0)
          Lit(value=20)
          Lit(value=20)
          Lit(value=600)
          Lit(value=320)
          Lit(value="matrix(1,0,0,1,0,0)")
        }
        Call(target=debugEmitSceneNode) {
          Lit(value=1)
          Lit(value=2)
          Lit(value="hello_text")
          Lit(value="root")
          Lit(value="Text")
          Lit(value="#ffffff")
          Lit(value="")
          Lit(value=0)
          Var(name=greeting)
          Lit(value="")
          Lit(value=28)
          Lit(value=208)
          Lit(value=180)
          Lit(value=0)
          Lit(value=0)
          Lit(value="matrix(1,0,0,1,0,0)")
        }
        Call(target=waitForCloseHello) { Var(name=handle) Var(name=greeting) }
        Return { Var(name=handle) }
      }
    }
  }

  Let(name=waitForCloseHello) {
    Fn(params=windowHandle,greeting) {
      Block {
        Loop {
          Block {
            Call(target=drawHelloFrame) { Var(name=windowHandle) Var(name=greeting) }
            Call(target=sys.ui.waitFrame) { Var(name=windowHandle) }
            Let(name=evt) { Call(target=sys.ui.pollEvent) { Var(name=windowHandle) } }
            If {
              Eq { AttrCount { Var(name=evt) } Lit(value=0) }
              Block { Continue { } }
              Block { Lit(value=0) }
            }
            If {
              Eq {
                Call(target=attrString) { Var(name=evt) Lit(value="type") Lit(value=0) }
                Lit(value="closed")
              }
              Block { Break { } }
              Block { Continue { } }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=drawHelloFrame) {
    Fn(params=windowHandle,greeting) {
      Block {
        Call(target=sys.ui.beginFrame) { Var(name=windowHandle) }
        Call(target=rect) { Var(name=windowHandle) }
        Call(target=label) { Var(name=windowHandle) Var(name=greeting) }
        Call(target=sys.ui.endFrame) { Var(name=windowHandle) }
        Call(target=sys.ui.present) { Var(name=windowHandle) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=waitForClose) {
    Fn(params=windowHandle) {
      Block {
        Loop {
          Block {
            Call(target=sys.ui.waitFrame) { Var(name=windowHandle) }
            Let(name=evt) { Call(target=sys.ui.pollEvent) { Var(name=windowHandle) } }
            If {
              Eq { AttrCount { Var(name=evt) } Lit(value=0) }
              Block { Continue { } }
              Block { Lit(value=0) }
            }
            If {
              Eq {
                Call(target=attrString) { Var(name=evt) Lit(value="type") Lit(value=0) }
                Lit(value="closed")
              }
              Block { Break { } }
              Block { Continue { } }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=attrString) {
    Fn(params=node,key,index) {
      Block {
        If {
          Eq { Var(name=index) AttrCount { Var(name=node) } }
          Block { Return { Lit(value="") } }
          Block {
            If {
              Eq { AttrKey { Var(name=node) Var(name=index) } Var(name=key) }
              Block { Return { AttrValueString { Var(name=node) Var(name=index) } } }
              Block {
                Return {
                  Call(target=attrString) {
                    Var(name=node)
                    Var(name=key)
                    Add { Var(name=index) Lit(value=1) }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=attrInt) {
    Fn(params=node,key,index) {
      Block {
        If {
          Eq { Var(name=index) AttrCount { Var(name=node) } }
          Block { Return { Lit(value=-1) } }
          Block {
            If {
              Eq { AttrKey { Var(name=node) Var(name=index) } Var(name=key) }
              Block { Return { AttrValueInt { Var(name=node) Var(name=index) } } }
              Block {
                Return {
                  Call(target=attrInt) {
                    Var(name=node)
                    Var(name=key)
                    Add { Var(name=index) Lit(value=1) }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=uiWidth) {
    Fn(params=handle) {
      Block {
        Return {
          Call(target=attrInt) {
            Call(target=sys.ui.getWindowSize) { Var(name=handle) }
            Lit(value="width")
            Lit(value=0)
          }
        }
      }
    }
  }

  Let(name=uiHeight) {
    Fn(params=handle) {
      Block {
        Return {
          Call(target=attrInt) {
            Call(target=sys.ui.getWindowSize) { Var(name=handle) }
            Lit(value="height")
            Lit(value=0)
          }
        }
      }
    }
  }

  Let(name=drawPanel) {
    Fn(params=handle,windowWidth,windowHeight) {
      Block {
        Call(target=drawGaussianBlurRect) {
          Var(name=handle)
          Lit(value=20)
          Lit(value=20)
          Add { Var(name=windowWidth) Lit(value=-40) }
          Add { Var(name=windowHeight) Lit(value=-40) }
          Lit(value=12)
        }
        Call(target=drawLinearGradientRect) {
          Var(name=handle)
          Lit(value=20)
          Lit(value=20)
          Add { Var(name=windowWidth) Lit(value=-40) }
          Add { Var(name=windowHeight) Lit(value=-40) }
          Lit(value="#1e293b")
          Lit(value="#334155")
          Lit(value="#1e293b")
          Lit(value=8)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=blurBandColor) {
    Fn(params=current,maxRadius) {
      Block {
        Let(name=half) { Call(target=halfFloor) { Var(name=maxRadius) Lit(value=0) } }
        Let(name=quarter) { Call(target=halfFloor) { Var(name=half) Lit(value=0) } }
        If {
          Eq { Var(name=current) Var(name=maxRadius) }
          Block { Return { Lit(value="#020617") } }
          Block {
            If {
              Call(target=intLt) { Var(name=half) Var(name=current) }
              Block { Return { Lit(value="#0f172a") } }
              Block {
                If {
                  Call(target=intLt) { Var(name=quarter) Var(name=current) }
                  Block { Return { Lit(value="#172554") } }
                  Block { Return { Lit(value="#1e293b") } }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=drawGaussianBlurRect) {
    Fn(params=handle,x,y,w,h,radius) {
      Block {
        Let(name=effectiveRadius) {
          If {
            Call(target=intLt) { Var(name=radius) Lit(value=1) }
            Block { Lit(value=1) }
            Block {
              If {
                Call(target=intLt) { Lit(value=12) Var(name=radius) }
                Block { Lit(value=12) }
                Block { Var(name=radius) }
              }
            }
          }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=1) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=1) } Call(target=sub) { Var(name=y) Lit(value=1) } Add { Var(name=w) Lit(value=2) } Add { Var(name=h) Lit(value=2) } Call(target=blurBandColor) { Lit(value=1) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=2) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=2) } Call(target=sub) { Var(name=y) Lit(value=2) } Add { Var(name=w) Lit(value=4) } Add { Var(name=h) Lit(value=4) } Call(target=blurBandColor) { Lit(value=2) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=3) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=3) } Call(target=sub) { Var(name=y) Lit(value=3) } Add { Var(name=w) Lit(value=6) } Add { Var(name=h) Lit(value=6) } Call(target=blurBandColor) { Lit(value=3) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=4) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=4) } Call(target=sub) { Var(name=y) Lit(value=4) } Add { Var(name=w) Lit(value=8) } Add { Var(name=h) Lit(value=8) } Call(target=blurBandColor) { Lit(value=4) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=5) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=5) } Call(target=sub) { Var(name=y) Lit(value=5) } Add { Var(name=w) Lit(value=10) } Add { Var(name=h) Lit(value=10) } Call(target=blurBandColor) { Lit(value=5) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=6) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=6) } Call(target=sub) { Var(name=y) Lit(value=6) } Add { Var(name=w) Lit(value=12) } Add { Var(name=h) Lit(value=12) } Call(target=blurBandColor) { Lit(value=6) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=7) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=7) } Call(target=sub) { Var(name=y) Lit(value=7) } Add { Var(name=w) Lit(value=14) } Add { Var(name=h) Lit(value=14) } Call(target=blurBandColor) { Lit(value=7) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=8) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=8) } Call(target=sub) { Var(name=y) Lit(value=8) } Add { Var(name=w) Lit(value=16) } Add { Var(name=h) Lit(value=16) } Call(target=blurBandColor) { Lit(value=8) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=9) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=9) } Call(target=sub) { Var(name=y) Lit(value=9) } Add { Var(name=w) Lit(value=18) } Add { Var(name=h) Lit(value=18) } Call(target=blurBandColor) { Lit(value=9) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=10) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=10) } Call(target=sub) { Var(name=y) Lit(value=10) } Add { Var(name=w) Lit(value=20) } Add { Var(name=h) Lit(value=20) } Call(target=blurBandColor) { Lit(value=10) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=11) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=11) } Call(target=sub) { Var(name=y) Lit(value=11) } Add { Var(name=w) Lit(value=22) } Add { Var(name=h) Lit(value=22) } Call(target=blurBandColor) { Lit(value=11) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        If {
          Call(target=intGte) { Var(name=effectiveRadius) Lit(value=12) }
          Block { Call(target=sys.ui.drawRect) { Var(name=handle) Call(target=sub) { Var(name=x) Lit(value=12) } Call(target=sub) { Var(name=y) Lit(value=12) } Add { Var(name=w) Lit(value=24) } Add { Var(name=h) Lit(value=24) } Call(target=blurBandColor) { Lit(value=12) Var(name=effectiveRadius) } } }
          Block { Lit(value=0) }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=gradientColor3) {
    Fn(params=offset,size,startColor,midColor,endColor) {
      Block {
        Let(name=half) { Call(target=halfFloor) { Var(name=size) Lit(value=0) } }
        Let(name=quarter) { Call(target=halfFloor) { Var(name=half) Lit(value=0) } }
        Let(name=threeQuarter) { Add { Var(name=half) Var(name=quarter) } }
        If {
          Call(target=intLt) { Var(name=offset) Var(name=quarter) }
          Block { Return { Var(name=startColor) } }
          Block {
            If {
              Call(target=intLt) { Var(name=offset) Var(name=threeQuarter) }
              Block { Return { Var(name=midColor) } }
              Block { Return { Var(name=endColor) } }
            }
          }
        }
      }
    }
  }

  Let(name=drawLinearGradientRectLoop) {
    Fn(params=handle,x,y,w,h,startColor,midColor,endColor,row,step) {
      Block {
        If {
          Call(target=intGte) { Var(name=row) Var(name=h) }
          Block { Return { Lit(value=0) } }
          Block {
            Let(name=color) {
              Call(target=gradientColor3) {
                Var(name=row)
                Var(name=h)
                Var(name=startColor)
                Var(name=midColor)
                Var(name=endColor)
              }
            }
            Call(target=sys.ui.drawRect) {
              Var(name=handle)
              Var(name=x)
              Add { Var(name=y) Var(name=row) }
              Var(name=w)
              Var(name=step)
              Var(name=color)
            }
            Return {
              Call(target=drawLinearGradientRectLoop) {
                Var(name=handle)
                Var(name=x)
                Var(name=y)
                Var(name=w)
                Var(name=h)
                Var(name=startColor)
                Var(name=midColor)
                Var(name=endColor)
                Add { Var(name=row) Var(name=step) }
                Var(name=step)
              }
            }
          }
        }
      }
    }
  }

  Let(name=drawLinearGradientRect) {
    Fn(params=handle,x,y,w,h,startColor,midColor,endColor,step) {
      Block {
        Let(name=topBand) { Call(target=halfFloor) { Var(name=h) Lit(value=0) } }
        Let(name=midBand) { Call(target=halfFloor) { Var(name=h) Lit(value=0) } }
        Let(name=bottomBand) {
          Call(target=sub) {
            Var(name=h)
            Add { Var(name=topBand) Var(name=midBand) }
          }
        }
        Call(target=sys.ui.drawRect) {
          Var(name=handle)
          Var(name=x)
          Var(name=y)
          Var(name=w)
          Var(name=topBand)
          Var(name=startColor)
        }
        Call(target=sys.ui.drawRect) {
          Var(name=handle)
          Var(name=x)
          Add { Var(name=y) Var(name=topBand) }
          Var(name=w)
          Var(name=midBand)
          Var(name=midColor)
        }
        Call(target=sys.ui.drawRect) {
          Var(name=handle)
          Var(name=x)
          Add { Add { Var(name=y) Var(name=topBand) } Var(name=midBand) }
          Var(name=w)
          Var(name=bottomBand)
          Var(name=endColor)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=translateCoord) {
    Fn(params=value,delta) {
      Block { Return { Add { Var(name=value) Var(name=delta) } } }
    }
  }

  Let(name=drawRectTransform) {
    Fn(params=handle,x,y,w,h,color,tx,ty) {
      Block {
        Call(target=sys.ui.drawRect) {
          Var(name=handle)
          Call(target=translateCoord) { Var(name=x) Var(name=tx) }
          Call(target=translateCoord) { Var(name=y) Var(name=ty) }
          Var(name=w)
          Var(name=h)
          Var(name=color)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=drawEllipseTransform) {
    Fn(params=handle,x,y,w,h,color,tx,ty) {
      Block {
        Call(target=sys.ui.drawEllipse) {
          Var(name=handle)
          Call(target=translateCoord) { Var(name=x) Var(name=tx) }
          Call(target=translateCoord) { Var(name=y) Var(name=ty) }
          Var(name=w)
          Var(name=h)
          Var(name=color)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=drawPathTransform) {
    Fn(params=handle,pathData,color,strokeWidth) {
      Block {
        Call(target=sys.ui.drawPath) {
          Var(name=handle)
          Var(name=pathData)
          Var(name=color)
          Var(name=strokeWidth)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=drawTextTransform) {
    Fn(params=handle,x,y,value,color,size,tx,ty) {
      Block {
        Call(target=sys.ui.drawText) {
          Var(name=handle)
          Call(target=translateCoord) { Var(name=x) Var(name=tx) }
          Call(target=translateCoord) { Var(name=y) Var(name=ty) }
          Var(name=value)
          Var(name=color)
          Var(name=size)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=interactiveFillForState) {
    Fn(params=state,normalFill,pressedFill,hoverFill,focusedFill,disabledFill) {
      Block {
        If {
          Eq { Var(name=state) Lit(value="pressed") }
          Block { Return { Var(name=pressedFill) } }
          Block {
            If {
              Eq { Var(name=state) Lit(value="hover") }
              Block { Return { Var(name=hoverFill) } }
              Block {
                If {
                  Eq { Var(name=state) Lit(value="focused") }
                  Block { Return { Var(name=focusedFill) } }
                  Block {
                    If {
                      Eq { Var(name=state) Lit(value="disabled") }
                      Block { Return { Var(name=disabledFill) } }
                      Block { Return { Var(name=normalFill) } }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=interactiveVectorState) {
    Fn(params=handle,x,y,w,h,state,shapeKind,pathData,normalFill,pressedFill,hoverFill,focusedFill,disabledFill) {
      Block {
        Let(name=fillColor) {
          Call(target=interactiveFillForState) {
            Var(name=state)
            Var(name=normalFill)
            Var(name=pressedFill)
            Var(name=hoverFill)
            Var(name=focusedFill)
            Var(name=disabledFill)
          }
        }
        If {
          Eq { Var(name=shapeKind) Lit(value="ellipse") }
          Block {
            Call(target=sys.ui.drawEllipse) {
              Var(name=handle)
              Var(name=x)
              Var(name=y)
              Var(name=w)
              Var(name=h)
              Var(name=fillColor)
            }
          }
          Block {
            If {
              Eq { Var(name=shapeKind) Lit(value="path") }
              Block {
                Call(target=sys.ui.drawPath) {
                  Var(name=handle)
                  Var(name=pathData)
                  Var(name=fillColor)
                  Lit(value=0)
                }
              }
              Block {
                Call(target=sys.ui.drawRect) {
                  Var(name=handle)
                  Var(name=x)
                  Var(name=y)
                  Var(name=w)
                  Var(name=h)
                  Var(name=fillColor)
                }
              }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=intLt) {
    Fn(params=a,b) {
      Block {
        If {
          Eq { Var(name=a) Var(name=b) }
          Block { Return { Lit(value=false) } }
          Block {
            If {
              Eq { Var(name=a) Lit(value=0) }
              Block { Return { Lit(value=true) } }
              Block {
                If {
                  Eq { Var(name=b) Lit(value=0) }
                  Block { Return { Lit(value=false) } }
                  Block {
                    Return {
                      Call(target=intLt) {
                        Add { Var(name=a) Lit(value=-1) }
                        Add { Var(name=b) Lit(value=-1) }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=intGte) {
    Fn(params=a,b) {
      Block {
        If {
          Call(target=intLt) { Var(name=a) Var(name=b) }
          Block { Return { Lit(value=false) } }
          Block { Return { Lit(value=true) } }
        }
      }
    }
  }

  Let(name=intLte) {
    Fn(params=a,b) {
      Block {
        If {
          Call(target=intLt) { Var(name=b) Var(name=a) }
          Block { Return { Lit(value=false) } }
          Block { Return { Lit(value=true) } }
        }
      }
    }
  }

  Let(name=pointInRect) {
    Fn(params=x,y,rx,ry,rw,rh) {
      Block {
        If {
          Call(target=intGte) { Var(name=x) Var(name=rx) }
          Block {
            If {
              Call(target=intLt) { Var(name=x) Add { Var(name=rx) Var(name=rw) } }
              Block {
                If {
                  Call(target=intGte) { Var(name=y) Var(name=ry) }
                  Block { Return { Call(target=intLt) { Var(name=y) Add { Var(name=ry) Var(name=rh) } } } }
                  Block { Return { Lit(value=false) } }
                }
              }
              Block { Return { Lit(value=false) } }
            }
          }
          Block { Return { Lit(value=false) } }
        }
      }
    }
  }

  Let(name=pointInEllipse) {
    Fn(params=x,y,ex,ey,ew,eh) {
      Block {
        Let(name=insideBounds) { Call(target=pointInRect) { Var(name=x) Var(name=y) Var(name=ex) Var(name=ey) Var(name=ew) Var(name=eh) } }
        If {
          Var(name=insideBounds)
          Block {
            Let(name=quarterX) { Call(target=halfFloor) { Call(target=halfFloor) { Var(name=ew) Lit(value=0) } Lit(value=0) } }
            Let(name=quarterY) { Call(target=halfFloor) { Call(target=halfFloor) { Var(name=eh) Lit(value=0) } Lit(value=0) } }
            Let(name=leftBand) { Add { Var(name=ex) Var(name=quarterX) } }
            Let(name=rightBand) { Add { Var(name=ex) Add { Var(name=quarterX) Add { Var(name=quarterX) Var(name=quarterX) } } } }
            Let(name=topBand) { Add { Var(name=ey) Var(name=quarterY) } }
            Let(name=bottomBand) { Add { Var(name=ey) Add { Var(name=quarterY) Add { Var(name=quarterY) Var(name=quarterY) } } } }
            Let(name=inMidX) {
              If {
                Call(target=intGte) { Var(name=x) Var(name=leftBand) }
                Block { Call(target=intLt) { Var(name=x) Var(name=rightBand) } }
                Block { Lit(value=false) }
              }
            }
            Let(name=inMidY) {
              If {
                Call(target=intGte) { Var(name=y) Var(name=topBand) }
                Block { Call(target=intLt) { Var(name=y) Var(name=bottomBand) } }
                Block { Lit(value=false) }
              }
            }
            If {
              Var(name=inMidX)
              Block { Return { Lit(value=true) } }
              Block { Return { Var(name=inMidY) } }
            }
          }
          Block { Return { Lit(value=false) } }
        }
      }
    }
  }

  Let(name=pointInPathBounds) {
    Fn(params=x,y,px,py,pw,ph) {
      Block {
        Return { Call(target=pointInRect) { Var(name=x) Var(name=y) Var(name=px) Var(name=py) Var(name=pw) Var(name=ph) } }
      }
    }
  }

  Let(name=resolveSize) {
    Fn(params=raw,current,defaultValue) {
      Block {
        If {
          Call(target=intLt) { Var(name=raw) Lit(value=1) }
          Block {
            If {
              Call(target=intLt) { Var(name=current) Lit(value=1) }
              Block { Return { Var(name=defaultValue) } }
              Block { Return { Var(name=current) } }
            }
          }
          Block { Return { Var(name=raw) } }
        }
      }
    }
  }

  Let(name=stabilizeSize) {
    Fn(params=raw,current,defaultValue) {
      Block {
        If {
          Call(target=intLt) { Var(name=raw) Lit(value=2) }
          Block {
            If {
              Call(target=intLt) { Var(name=current) Lit(value=2) }
              Block { Return { Var(name=defaultValue) } }
              Block { Return { Var(name=current) } }
            }
          }
          Block {
            If {
              Call(target=intLt) { Var(name=current) Lit(value=2) }
              Block { Return { Var(name=raw) } }
              Block {
                If {
                  Eq { Var(name=raw) Var(name=current) }
                  Block { Return { Var(name=current) } }
                  Block {
                    If {
                      Eq { Var(name=raw) Add { Var(name=current) Lit(value=1) } }
                      Block { Return { Var(name=current) } }
                      Block {
                        If {
                          Eq { Var(name=raw) Add { Var(name=current) Lit(value=-1) } }
                          Block { Return { Var(name=current) } }
                          Block {
                            If {
                              Eq { Var(name=raw) Add { Var(name=current) Lit(value=2) } }
                              Block { Return { Var(name=current) } }
                              Block {
                                If {
                                  Eq { Var(name=raw) Add { Var(name=current) Lit(value=-2) } }
                                  Block { Return { Var(name=current) } }
                                  Block {
                                    If {
                                      Eq { Var(name=raw) Add { Var(name=current) Var(name=current) } }
                                      Block { Return { Var(name=current) } }
                                      Block {
                                        If {
                                          Eq { Var(name=current) Add { Var(name=raw) Var(name=raw) } }
                                          Block { Return { Var(name=current) } }
                                          Block { Return { Var(name=raw) } }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=halfFloor) {
    Fn(params=value,acc) {
      Block {
        If {
          Eq { Var(name=value) Lit(value=0) }
          Block { Return { Var(name=acc) } }
          Block {
            If {
              Eq { Var(name=value) Lit(value=1) }
              Block { Return { Var(name=acc) } }
              Block {
                Return {
                  Call(target=halfFloor) {
                    Add { Var(name=value) Lit(value=-2) }
                    Add { Var(name=acc) Lit(value=1) }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=subAbs) {
    Fn(params=a,b) {
      Block {
        If {
          Call(target=intLt) { Var(name=a) Var(name=b) }
          Block { Return { Call(target=sub) { Var(name=b) Var(name=a) } } }
          Block { Return { Call(target=sub) { Var(name=a) Var(name=b) } } }
        }
      }
    }
  }

  Let(name=mul) {
    Fn(params=a,b,acc) {
      Block {
        If {
          Eq { Var(name=b) Lit(value=0) }
          Block { Return { Var(name=acc) } }
          Block {
            Return {
              Call(target=mul) {
                Var(name=a)
                Add { Var(name=b) Lit(value=-1) }
                Add { Var(name=acc) Var(name=a) }
              }
            }
          }
        }
      }
    }
  }

  Let(name=sub) {
    Fn(params=a,b) {
      Block {
        If {
          Eq { Var(name=b) Lit(value=0) }
          Block { Return { Var(name=a) } }
          Block { Return { Call(target=sub) { Add { Var(name=a) Lit(value=-1) } Add { Var(name=b) Lit(value=-1) } } } }
        }
      }
    }
  }

  Let(name=buttonX) {
    Fn(params=windowWidth) {
      Block {
        Return {
          Call(target=halfFloor) {
            Add { Var(name=windowWidth) Lit(value=-140) }
            Lit(value=0)
          }
        }
      }
    }
  }

  Let(name=buttonY) {
    Fn(params=windowHeight) {
      Block { Return { Add { Var(name=windowHeight) Lit(value=-160) } } }
    }
  }

  Let(name=inputWidth) {
    Fn(params=windowWidth) {
      Block { Return { Add { Var(name=windowWidth) Lit(value=-144) } } }
    }
  }

  Let(name=hintY) {
    Fn(params=windowHeight) {
      Block { Return { Add { Var(name=windowHeight) Lit(value=-92) } } }
    }
  }

  Let(name=statusY) {
    Fn(params=windowHeight) {
      Block { Return { Add { Var(name=windowHeight) Lit(value=-46) } } }
    }
  }

  Let(name=textLen) {
    Fn(params=textValue) {
      Block {
        If {
          Eq { Var(name=textValue) Lit(value="") }
          Block { Return { Lit(value=0) } }
          Block {
            Return {
              Add {
                Lit(value=1)
                Call(target=textLen) { Call(target=sys.str.remove) { Var(name=textValue) Lit(value=0) Lit(value=1) } }
              }
            }
          }
        }
      }
    }
  }

  Let(name=divFloor) {
    Fn(params=value,step,acc) {
      Block {
        If {
          Call(target=intLt) { Var(name=value) Var(name=step) }
          Block { Return { Var(name=acc) } }
          Block {
            Return {
              Call(target=divFloor) {
                Call(target=sub) { Var(name=value) Var(name=step) }
                Var(name=step)
                Add { Var(name=acc) Lit(value=1) }
              }
            }
          }
        }
      }
    }
  }

  Let(name=fitTextTail) {
    Fn(params=textValue,maxChars) {
      Block {
        If {
          Call(target=intLte) { Call(target=textLen) { Var(name=textValue) } Var(name=maxChars) }
          Block { Return { Var(name=textValue) } }
          Block {
            Return {
              Call(target=fitTextTail) {
                Call(target=sys.str.remove) { Var(name=textValue) Lit(value=0) Lit(value=1) }
                Var(name=maxChars)
              }
            }
          }
        }
      }
    }
  }

  Let(name=visibleTextTail) {
    Fn(params=textValue,fieldWidth) {
      Block {
        Let(name=contentWidth) {
          If {
            Call(target=intLt) { Var(name=fieldWidth) Lit(value=33) }
            Block { Lit(value=0) }
            Block { Call(target=sub) { Var(name=fieldWidth) Lit(value=32) } }
          }
        }
        Let(name=maxChars) { Call(target=divFloor) { Var(name=contentWidth) Lit(value=12) Lit(value=0) } }
        Return { Call(target=fitTextTail) { Var(name=textValue) Var(name=maxChars) } }
      }
    }
  }

  Let(name=textInsertAt) {
    Fn(params=textValue,index,chunk) {
      Block {
        Let(name=len) { Call(target=textLen) { Var(name=textValue) } }
        Let(name=idx) { Call(target=caretClamp) { Var(name=index) Var(name=len) } }
        Let(name=prefix) { Call(target=sys.str.substring) { Var(name=textValue) Lit(value=0) Var(name=idx) } }
        Let(name=suffixLen) { Call(target=sub) { Var(name=len) Var(name=idx) } }
        Let(name=suffix) { Call(target=sys.str.substring) { Var(name=textValue) Var(name=idx) Var(name=suffixLen) } }
        Return { StrConcat { ToString { Var(name=prefix) } StrConcat { ToString { Var(name=chunk) } ToString { Var(name=suffix) } } } }
      }
    }
  }

  Let(name=textDeleteAt) {
    Fn(params=textValue,index) {
      Block {
        Let(name=len) { Call(target=textLen) { Var(name=textValue) } }
        If {
          Eq { Var(name=len) Lit(value=0) }
          Block { Return { Var(name=textValue) } }
          Block {
            Let(name=idx) { Call(target=caretClamp) { Var(name=index) Var(name=len) } }
            If {
              Eq { Var(name=idx) Lit(value=0) }
              Block { Return { Var(name=textValue) } }
              Block {
                Return {
                  Call(target=sys.str.remove) {
                    Var(name=textValue)
                    Add { Var(name=idx) Lit(value=-1) }
                    Lit(value=1)
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=caretClamp) {
    Fn(params=caret,textLength) {
      Block {
        If {
          Call(target=intLt) { Var(name=caret) Lit(value=0) }
          Block { Return { Lit(value=0) } }
          Block {
            If {
              Call(target=intLt) { Var(name=textLength) Var(name=caret) }
              Block { Return { Var(name=textLength) } }
              Block { Return { Var(name=caret) } }
            }
          }
        }
      }
    }
  }

  Let(name=caretLeft) {
    Fn(params=caret) {
      Block {
        If {
          Eq { Var(name=caret) Lit(value=0) }
          Block { Return { Lit(value=0) } }
          Block { Return { Add { Var(name=caret) Lit(value=-1) } } }
        }
      }
    }
  }

  Let(name=caretRight) {
    Fn(params=caret,textLength) {
      Block {
        If {
          Call(target=intLt) { Var(name=caret) Var(name=textLength) }
          Block { Return { Add { Var(name=caret) Lit(value=1) } } }
          Block { Return { Var(name=textLength) } }
        }
      }
    }
  }

  Let(name=textPrefix) {
    Fn(params=textValue,caret) {
      Block { Return { Call(target=sys.str.substring) { Var(name=textValue) Lit(value=0) Var(name=caret) } } }
    }
  }

  Let(name=caretPixelOffset) {
    Fn(params=textValue,caret,charWidth) {
      Block {
        Let(name=prefix) { Call(target=textPrefix) { Var(name=textValue) Var(name=caret) } }
        Return { Call(target=mul) { Var(name=charWidth) Call(target=textLen) { Var(name=prefix) } Lit(value=0) } }
      }
    }
  }

  Let(name=removeLastChar) {
    Fn(params=textValue) {
      Block {
        Let(name=len) { Call(target=textLen) { Var(name=textValue) } }
        If {
          Eq { Var(name=len) Lit(value=0) }
          Block { Return { Var(name=textValue) } }
          Block {
            Return {
              Call(target=sys.str.remove) {
                Var(name=textValue)
                Add { Var(name=len) Lit(value=-1) }
                Lit(value=1)
              }
            }
          }
        }
      }
    }
  }

  Let(name=mapGetString) {
    Fn(params=map,key,index) {
      Block {
        If {
          Eq { Var(name=index) ChildCount { Var(name=map) } }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=field) { ChildAt { Var(name=map) Var(name=index) } }
            If {
              Eq { AttrValueString { Var(name=field) Lit(value=0) } Var(name=key) }
              Block { Return { AttrValueString { ChildAt { Var(name=field) Lit(value=0) } Lit(value=0) } } }
              Block {
                Return {
                  Call(target=mapGetString) {
                    Var(name=map)
                    Var(name=key)
                    Add { Var(name=index) Lit(value=1) }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=keyTextMap) {
    Fn(params=_) {
      Block {
        Return {
          Map {
            Field(key="a") { Lit(value="a") }
            Field(key="b") { Lit(value="b") }
            Field(key="c") { Lit(value="c") }
            Field(key="d") { Lit(value="d") }
            Field(key="e") { Lit(value="e") }
            Field(key="f") { Lit(value="f") }
            Field(key="g") { Lit(value="g") }
            Field(key="h") { Lit(value="h") }
