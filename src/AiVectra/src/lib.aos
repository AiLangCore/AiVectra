            Field(key=";") { Lit(value=";") }
            Field(key="!") { Lit(value="!") }
            Field(key="?") { Lit(value="?") }
            Field(key="@") { Lit(value="@") }
            Field(key="#") { Lit(value="#") }
            Field(key="$") { Lit(value="$") }
            Field(key="%") { Lit(value="%") }
            Field(key="&") { Lit(value="&") }
            Field(key="+") { Lit(value="+") }
            Field(key="=") { Lit(value="=") }
            Field(key="/") { Lit(value="/") }
            Field(key="\\") { Lit(value="\\") }
            Field(key="(") { Lit(value="(") }
            Field(key=")") { Lit(value=")") }
            Field(key="[") { Lit(value="[") }
            Field(key="]") { Lit(value="]") }
            Field(key="{") { Lit(value="{") }
            Field(key="}") { Lit(value="}") }
          }
        }
      }
    }
  }

  Let(name=keyToText) {
    Fn(params=keyName) {
      Block {
        Return {
          Call(target=mapGetString) {
            Call(target=keyTextMap) { Lit(value=0) }
            Var(name=keyName)
            Lit(value=0)
          }
        }
      }
    }
  }

  Let(name=debugSizeLine) {
    Fn(params=rawWidth,rawHeight,stableWidth,stableHeight) {
      Block {
        Call(target=sys.stdout.writeLine) {
          StrConcat {
            Lit(value="[aivectra] size raw=")
            StrConcat {
              ToString { Var(name=rawWidth) }
              StrConcat {
                Lit(value="x")
                StrConcat {
                  ToString { Var(name=rawHeight) }
                  StrConcat {
                    Lit(value=" stable=")
                    StrConcat {
                      ToString { Var(name=stableWidth) }
                      StrConcat {
                        Lit(value="x")
                        ToString { Var(name=stableHeight) }
                      }
                    }
                  }
                }
              }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugEventLine) {
    Fn(params=eventType,keyName,textValue,clickX,clickY) {
      Block {
        Let(name=keyToken) { Call(target=debugInputToken) { Var(name=keyName) } }
        Let(name=textToken) { Call(target=debugInputToken) { Var(name=textValue) } }
        Call(target=sys.stdout.writeLine) { Lit(value="[[aivectra.event]]") }
        Call(target=sys.stdout.writeLine) { StrConcat { Lit(value="type=\"") StrConcat { ToString { Var(name=eventType) } Lit(value="\"") } } }
        Call(target=sys.stdout.writeLine) { StrConcat { Lit(value="key=\"") StrConcat { ToString { Var(name=keyToken) } Lit(value="\"") } } }
        Call(target=sys.stdout.writeLine) { StrConcat { Lit(value="text=\"") StrConcat { ToString { Var(name=textToken) } Lit(value="\"") } } }
        Call(target=sys.stdout.writeLine) { StrConcat { Lit(value="x=") ToString { Var(name=clickX) } } }
        Call(target=sys.stdout.writeLine) { StrConcat { Lit(value="y=") ToString { Var(name=clickY) } } }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugControlName) {
    Fn(params=value) {
      Block {
        If {
          Eq { Var(name=value) Lit(value="backspace") }
          Block { Return { Lit(value="backspace") } }
          Block {
            If {
              Eq { Var(name=value) Lit(value="Backspace") }
              Block { Return { Lit(value="backspace") } }
              Block {
                If {
                  Eq { Var(name=value) Lit(value="DeleteBackward") }
                  Block { Return { Lit(value="backspace") } }
                  Block {
                    If {
                      Eq { Var(name=value) Lit(value="delete_backward") }
                      Block { Return { Lit(value="backspace") } }
                      Block {
                        If {
                          Eq { Var(name=value) Lit(value="x11:22") }
                          Block { Return { Lit(value="backspace") } }
                          Block {
                            If {
                              Eq { Var(name=value) Lit(value="x11:107") }
                              Block { Return { Lit(value="backspace") } }
                              Block {
                                If {
                                  Eq { Var(name=value) Lit(value="enter") }
                                  Block { Return { Lit(value="enter") } }
                                  Block {
                                    If {
                                      Eq { Var(name=value) Lit(value="Enter") }
                                      Block { Return { Lit(value="enter") } }
                                      Block {
                                        If {
                                          Eq { Var(name=value) Lit(value="return") }
                                          Block { Return { Lit(value="enter") } }
                                          Block {
                                            If {
                                              Eq { Var(name=value) Lit(value="Return") }
                                              Block { Return { Lit(value="enter") } }
                                              Block {
                                                If {
                                                  Eq { Var(name=value) Lit(value="kp_enter") }
                                                  Block { Return { Lit(value="enter") } }
                                                  Block {
                                                    If {
                                                      Eq { Var(name=value) Lit(value="Delete") }
                                                      Block { Return { Lit(value="delete") } }
                                                      Block {
                                                        If {
                                                          Eq { Var(name=value) Lit(value="delete") }
                                                          Block { Return { Lit(value="delete") } }
                                                          Block { Return { Lit(value="") } }
                                                        }
                                                      }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=debugInputToken) {
    Fn(params=value) {
      Block {
        If {
          Eq { Var(name=value) Lit(value="") }
          Block { Return { Lit(value="<empty>") } }
          Block {
            Let(name=controlName) { Call(target=debugControlName) { Var(name=value) } }
            If {
              Eq { Var(name=controlName) Lit(value="") }
              Block {
                Let(name=mapped) { Call(target=keyToText) { Var(name=value) } }
                If {
                  Eq { Var(name=mapped) Lit(value="") }
                  Block {
                    Return {
                      StrConcat {
                        Lit(value="<raw:")
                        StrConcat { ToString { Call(target=textLen) { Var(name=value) } } Lit(value="b>") }
                      }
                    }
                  }
                  Block {
                    Return {
                      StrConcat {
                        Lit(value="'")
                        StrConcat { ToString { Var(name=mapped) } Lit(value="'") }
                      }
                    }
                  }
                }
              }
              Block {
                Return {
                  StrConcat {
                    Lit(value="<")
                    StrConcat { ToString { Var(name=controlName) } Lit(value=">") }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=debugLayoutLine) {
    Fn(params=windowWidth,windowHeight) {
      Block {
        Call(target=sys.stdout.writeLine) { Call(target=layoutSignature) { Var(name=windowWidth) Var(name=windowHeight) } }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugEmitEvent) {
    Fn(params=eventType,keyName,textValue,clickX,clickY) {
      Block {
        Let(name=keyToken) { Call(target=debugInputToken) { Var(name=keyName) } }
        Let(name=textToken) { Call(target=debugInputToken) { Var(name=textValue) } }
        Call(target=sys.stdout.writeLine) {
          StrConcat {
            Lit(value="aivectra.event = { type=\"")
            StrConcat {
              ToString { Var(name=eventType) }
              StrConcat {
                Lit(value="\", key=\"")
                StrConcat {
                  ToString { Var(name=keyToken) }
                  StrConcat {
                    Lit(value="\", text=\"")
                    StrConcat {
                      ToString { Var(name=textToken) }
                      StrConcat {
                        Lit(value="\", x=")
                        StrConcat {
                          ToString { Var(name=clickX) }
                          StrConcat {
                            Lit(value=", y=")
                            StrConcat {
                              ToString { Var(name=clickY) }
                              Lit(value=" }")
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugEmitUi) {
    Fn(params=action,target,inputFocused,nameLen,submittedLen,inputRect,buttonRect) {
      Block {
        Call(target=sys.stdout.writeLine) {
          StrConcat {
            Lit(value="aivectra.ui = { action=\"")
            StrConcat {
              ToString { Var(name=action) }
              StrConcat {
                Lit(value="\", target=\"")
                StrConcat {
                  ToString { Var(name=target) }
                  StrConcat {
                    Lit(value="\", focus=")
                    StrConcat {
                      If { Var(name=inputFocused) Block { Lit(value="true") } Block { Lit(value="false") } }
                      StrConcat {
                        Lit(value=", name_len=")
                        StrConcat {
                          ToString { Var(name=nameLen) }
                          StrConcat {
                            Lit(value=", submitted_len=")
                            StrConcat {
                              ToString { Var(name=submittedLen) }
                              StrConcat {
                                Lit(value=", input_rect=\"")
                                StrConcat {
                                  ToString { Var(name=inputRect) }
                                  StrConcat {
                                    Lit(value="\", button_rect=\"")
                                    StrConcat {
                                      ToString { Var(name=buttonRect) }
                                      Lit(value="\" }")
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugEmitSceneNode) {
    Fn(params=frame,order,id,parent,kind,fill,stroke,strokeWidth,textValue,pathValue,fontSize,x,y,w,h,transform) {
      Block {
        Call(target=sys.stdout.writeLine) {
          StrConcat {
            Lit(value="aivectra.scene = { frame=")
            StrConcat {
              ToString { Var(name=frame) }
              StrConcat {
                Lit(value=", order=")
                StrConcat {
                  ToString { Var(name=order) }
                  StrConcat {
                    Lit(value=", id=\"")
                    StrConcat {
                      ToString { Var(name=id) }
                      StrConcat {
                        Lit(value="\", parent=\"")
                        StrConcat {
                          ToString { Var(name=parent) }
                          StrConcat {
                            Lit(value="\", kind=\"")
                            StrConcat {
                              ToString { Var(name=kind) }
                              StrConcat {
                                Lit(value="\", fill=\"")
                                StrConcat {
                                  ToString { Var(name=fill) }
                                  StrConcat {
                                    Lit(value="\", stroke=\"")
                                    StrConcat {
                                      ToString { Var(name=stroke) }
                                      StrConcat {
                                        Lit(value="\", stroke_w=")
                                        StrConcat {
                                          ToString { Var(name=strokeWidth) }
                                          StrConcat {
                                            Lit(value=", text=\"")
                                            StrConcat {
                                              ToString { Var(name=textValue) }
                                              StrConcat {
                                                Lit(value="\", path=\"")
                                                StrConcat {
                                                  ToString { Var(name=pathValue) }
                                                  StrConcat {
                                                    Lit(value="\", font_size=")
                                                    StrConcat {
                                                      ToString { Var(name=fontSize) }
                                                      StrConcat {
                                                        Lit(value=", x=")
                                                        StrConcat {
                                                          ToString { Var(name=x) }
                                                          StrConcat {
                                                            Lit(value=", y=")
                                                            StrConcat {
                                                              ToString { Var(name=y) }
                                                              StrConcat {
                                                                Lit(value=", w=")
                                                                StrConcat {
                                                                  ToString { Var(name=w) }
                                                                  StrConcat {
                                                                    Lit(value=", h=")
                                                                    StrConcat {
                                                                      ToString { Var(name=h) }
                                                                      StrConcat {
                                                                        Lit(value=", transform=\"")
                                                                        StrConcat {
                                                                          ToString { Var(name=transform) }
                                                                          Lit(value="\" }")
                                                                        }
                                                                      }
                                                                    }
                                                                  }
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=debugEmitEventIf) {
    Fn(params=enabled,eventType,keyName,textValue,clickX,clickY) {
      Block {
        If {
          Var(name=enabled)
          Block { Return { Call(target=debugEmitEvent) { Var(name=eventType) Var(name=keyName) Var(name=textValue) Var(name=clickX) Var(name=clickY) } } }
          Block { Return { Lit(value=0) } }
        }
      }
    }
  }

  Let(name=debugEmitUiIf) {
    Fn(params=enabled,action,target,inputFocused,nameLen,submittedLen,inputRect,buttonRect) {
      Block {
        If {
          Var(name=enabled)
          Block { Return { Call(target=debugEmitUi) { Var(name=action) Var(name=target) Var(name=inputFocused) Var(name=nameLen) Var(name=submittedLen) Var(name=inputRect) Var(name=buttonRect) } } }
          Block { Return { Lit(value=0) } }
        }
      }
    }
  }

  Let(name=debugEmitSceneNodeIf) {
    Fn(params=enabled,frame,order,id,parent,kind,fill,stroke,strokeWidth,textValue,pathValue,fontSize,x,y,w,h,transform) {
      Block {
        If {
          Var(name=enabled)
          Block { Return { Call(target=debugEmitSceneNode) { Var(name=frame) Var(name=order) Var(name=id) Var(name=parent) Var(name=kind) Var(name=fill) Var(name=stroke) Var(name=strokeWidth) Var(name=textValue) Var(name=pathValue) Var(name=fontSize) Var(name=x) Var(name=y) Var(name=w) Var(name=h) Var(name=transform) } } }
          Block { Return { Lit(value=0) } }
        }
      }
    }
  }

  Let(name=debugModeLive) {
    Fn(params=mode) {
      Block {
        If {
          Eq { Var(name=mode) Lit(value="live") }
          Block { Return { Lit(value=true) } }
          Block { Return { Lit(value=false) } }
        }
      }
    }
  }

  Let(name=debugModeScene) {
    Fn(params=mode) {
      Block {
        If {
          Eq { Var(name=mode) Lit(value="scene") }
          Block { Return { Lit(value=true) } }
          Block { Return { Lit(value=false) } }
        }
      }
    }
  }

  Let(name=debugModeEventsOrLive) {
    Fn(params=mode) {
      Block {
        If {
          Eq { Var(name=mode) Lit(value="events") }
          Block { Return { Lit(value=true) } }
          Block { Return { Call(target=debugModeLive) { Var(name=mode) } } }
        }
      }
    }
  }

  Let(name=debugModeSceneOrLive) {
    Fn(params=mode) {
      Block {
        If {
          Eq { Var(name=mode) Lit(value="scene") }
          Block { Return { Lit(value=true) } }
          Block { Return { Call(target=debugModeLive) { Var(name=mode) } } }
        }
      }
    }
  }

  Let(name=debugModeEventsSceneOrLive) {
    Fn(params=mode) {
      Block {
        If {
          Eq { Var(name=mode) Lit(value="events") }
          Block { Return { Lit(value=true) } }
          Block { Return { Call(target=debugModeSceneOrLive) { Var(name=mode) } } }
        }
      }
    }
  }

  Let(name=argStringAt) {
    Fn(params=args,index) {
      Block {
        If {
          Eq { Var(name=index) ChildCount { Var(name=args) } }
          Block { Return { Lit(value="") } }
          Block { Return { AttrValueString { ChildAt { Var(name=args) Var(name=index) } Lit(value=0) } } }
        }
      }
    }
  }

  Let(name=appModeFromArgsAt) {
    Fn(params=args,index) {
      Block {
        If {
          Eq { Var(name=index) ChildCount { Var(name=args) } }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=candidate) { Call(target=argStringAt) { Var(name=args) Var(name=index) } }
            If {
              Eq { Var(name=candidate) Lit(value="live") }
              Block { Return { Lit(value="live") } }
              Block {
                If {
                  Eq { Var(name=candidate) Lit(value="snapshot") }
                  Block { Return { Lit(value="snapshot") } }
                  Block {
                    If {
                      Eq { Var(name=candidate) Lit(value="replay") }
                      Block { Return { Lit(value="replay") } }
                      Block {
                        If {
                          Eq { Var(name=candidate) Lit(value="scene") }
                          Block { Return { Lit(value="scene") } }
                          Block {
                            If {
                              Eq { Var(name=candidate) Lit(value="events") }
                              Block { Return { Lit(value="events") } }
                              Block {
                                Return {
                                  Call(target=appModeFromArgsAt) {
                                    Var(name=args)
                                    Add { Var(name=index) Lit(value=1) }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=appModeFromArgs) {
    Fn(params=args) {
      Block { Return { Call(target=appModeFromArgsAt) { Var(name=args) Lit(value=0) } } }
    }
  }

  Let(name=layoutSignature) {
    Fn(params=windowWidth,windowHeight) {
      Block {
        Let(name=entryWidth) { Call(target=inputWidth) { Var(name=windowWidth) } }
        Let(name=submitX) { Call(target=buttonX) { Var(name=windowWidth) } }
        Let(name=submitY) { Call(target=buttonY) { Var(name=windowHeight) } }
        Let(name=hintTextY) { Call(target=hintY) { Var(name=windowHeight) } }
        Let(name=statusTextY) { Call(target=statusY) { Var(name=windowHeight) } }
        Return {
          StrConcat {
            Lit(value="[aivectra] layout panel=20,20,")
            StrConcat {
              ToString { Add { Var(name=windowWidth) Lit(value=-40) } }
              StrConcat {
                Lit(value=",")
                StrConcat {
                  ToString { Add { Var(name=windowHeight) Lit(value=-40) } }
                  StrConcat {
                    Lit(value=" input=72,112,")
                    StrConcat {
                      ToString { Var(name=entryWidth) }
                      StrConcat {
                        Lit(value=",52 button=")
                        StrConcat {
                          ToString { Var(name=submitX) }
                          StrConcat {
                            Lit(value=",")
                            StrConcat {
                              ToString { Var(name=submitY) }
                              StrConcat {
                                Lit(value=",140,52 hintY=")
                                StrConcat {
                                  ToString { Var(name=hintTextY) }
                                  StrConcat {
                                    Lit(value=" statusY=")
                                    ToString { Var(name=statusTextY) }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

