        Let(name=endPos) { Call(target=findFrom) { Var(name=line) Lit(value=" C") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=endPos) }
          Block { Return { Lit(value="--") } }
          Block {
            Return {
              StrConcat {
                Call(target=sys.str.substring) {
                  Var(name=line)
                  Lit(value=5)
                  Call(target=sub) { Var(name=endPos) Lit(value=5) }
                }
                Lit(value=" C")
              }
            }
          }
        }
      }
    }
  }

  Let(name=currentConditionText) {
    Fn(params=forecastBody) {
      Block {
        Let(name=line) { Call(target=currentLineFromForecast) { Var(name=forecastBody) } }
        Let(name=startPos) { Call(target=findFrom) { Var(name=line) Lit(value=" C  ") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=startPos) }
          Block { Return { Lit(value="Weather unavailable") } }
          Block {
            Let(name=textStart) { Add { Var(name=startPos) Lit(value=4) } }
            Return {
