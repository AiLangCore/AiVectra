  Let(name=submitQueryAndState) {
    Fn(params=query,selectedLabel,selectedLat,selectedLon,forecastBody,radarOpen,nextRadarTick,radarImageRgba,w,h,debugLive) {
      Block {
        Call(target=traceNetLine) { Var(name=debugLive) Lit(value="submit.begin") Var(name=query) ToString { Call(target=strLen) { Var(name=query) } } }
        If {
          Eq { Var(name=query) Lit(value="") }
          Block {
            Call(target=traceNetLine) { Var(name=debugLive) Lit(value="submit.skip.empty") Lit(value="query") Lit(value="0") }
            Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Enter a ZIP or city first.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
          }
          Block { Lit(value=0) }
        }
        Call(target=traceNetLine) { Var(name=debugLive) Lit(value="geo.request") Var(name=query) Lit(value="open-meteo") }
        Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Loading weather...") Var(name=radarOpen) Var(name=nextRadarTick) Lit(value="") Var(name=w) Var(name=h) Lit(value=12) Lit(value=0) Lit(value="geo_start") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
      }
    }
