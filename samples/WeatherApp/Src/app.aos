Program {
  Import(path="../../../.tools/std/core.aos")
  Import(path="../../../.tools/std/image.aos")
  Import(path="../../../src/AiVectra/src/lib.aos")
  Import(path="../../../.tools/sys/http.aos")
  Export(name=start)

  Let(name=strLen) {
    Fn(params=text) {
      Block { Return { Call(target=textLen) { Var(name=text) } } }
    }
  }

  Let(name=findFrom) {
    Fn(params=text,pattern,index) {
      Block {
        Return { Call(target=sys.str.find) { Var(name=text) Var(name=pattern) Var(name=index) } }
      }
    }
  }

  Let(name=findNotFound) {
    Fn(params=index) {
      Block { Return { Eq { Var(name=index) Lit(value=-1) } } }
    }
  }

  Let(name=contains) {
    Fn(params=text,pattern) {
      Block {
        Let(name=found) { Call(target=findFrom) { Var(name=text) Var(name=pattern) Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=found) }
          Block { Return { Lit(value=false) } }
          Block { Return { Lit(value=true) } }
        }
      }
    }
  }

  Let(name=minPositive) {
    Fn(params=a,b,fallback) {
      Block {
        If {
          Call(target=findNotFound) { Var(name=a) }
          Block {
            If {
              Call(target=findNotFound) { Var(name=b) }
              Block { Return { Var(name=fallback) } }
              Block { Return { Var(name=b) } }
            }
          }
          Block {
            If {
              Call(target=findNotFound) { Var(name=b) }
              Block { Return { Var(name=a) } }
              Block {
                If {
                  Call(target=intLt) { Var(name=a) Var(name=b) }
                  Block { Return { Var(name=a) } }
                  Block { Return { Var(name=b) } }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=bodyFromHttp) {
    Fn(params=response) {
      Block {
        Let(name=sep) { Call(target=findFrom) { Var(name=response) Lit(value="\r\n\r\n") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=sep) }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=bodyStart) { Add { Var(name=sep) Lit(value=4) } }
            Return {
              Call(target=sys.str.substring) {
                Var(name=response)
                Var(name=bodyStart)
                Call(target=sub) { Call(target=strLen) { Var(name=response) } Var(name=bodyStart) }
              }
            }
          }
        }
      }
    }
  }

  Let(name=httpResponseBodyText) {
    Fn(params=requestState) {
      Block {
        Let(name=responseBytes) { Call(target=httpRequestResponseBytes) { Var(name=requestState) } }
        Let(name=bodyBytes) { Call(target=httpResponseBodyBytes) { Var(name=responseBytes) } }
        Return { Call(target=sys.bytes.toUtf8String) { Var(name=bodyBytes) } }
      }
    }
  }

  Let(name=replaceSpaces) {
    Fn(params=text) {
      Block {
        Return { Call(target=replaceSpacesAt) { Var(name=text) Lit(value=0) Lit(value="") } }
      }
    }
  }

  Let(name=replaceSpacesAt) {
    Fn(params=text,index,acc) {
      Block {
        If {
          Call(target=intLt) { Var(name=index) Call(target=strLen) { Var(name=text) } }
          Block {
            Let(name=ch) { Call(target=sys.str.substring) { Var(name=text) Var(name=index) Lit(value=1) } }
            If {
              Eq { Var(name=ch) Lit(value=" ") }
              Block {
                Return {
                  Call(target=replaceSpacesAt) {
                    Var(name=text)
                    Add { Var(name=index) Lit(value=1) }
                    StrConcat { Var(name=acc) Lit(value="%20") }
                  }
                }
              }
              Block {
                Return {
                  Call(target=replaceSpacesAt) {
                    Var(name=text)
                    Add { Var(name=index) Lit(value=1) }
                    StrConcat { Var(name=acc) Var(name=ch) }
                  }
                }
              }
            }
          }
          Block { Return { Var(name=acc) } }
        }
      }
    }
  }

  Let(name=nthPos) {
    Fn(params=text,token,start,n) {
      Block {
        If {
          Call(target=intLt) { Var(name=n) Lit(value=1) }
          Block { Return { Lit(value=-1) } }
          Block {
            Let(name=found) { Call(target=findFrom) { Var(name=text) Var(name=token) Var(name=start) } }
            If {
              Call(target=findNotFound) { Var(name=found) }
              Block { Return { Lit(value=-1) } }
              Block {
                If {
                  Eq { Var(name=n) Lit(value=1) }
                  Block { Return { Var(name=found) } }
                  Block {
                    Return {
                      Call(target=nthPos) {
                        Var(name=text)
                        Var(name=token)
                        Add { Var(name=found) Call(target=strLen) { Var(name=token) } }
                        Add { Var(name=n) Lit(value=-1) }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=quotedValueAt) {
    Fn(params=text,token,start,n) {
      Block {
        If {
          Call(target=intLt) { Call(target=strLen) { Var(name=text) } Lit(value=1) }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=pos) { Call(target=nthPos) { Var(name=text) Var(name=token) Var(name=start) Var(name=n) } }
            If {
              Call(target=findNotFound) { Var(name=pos) }
              Block { Return { Lit(value="") } }
              Block {
                Let(name=valueStart) { Add { Var(name=pos) Call(target=strLen) { Var(name=token) } } }
                Let(name=valueEnd) { Call(target=findFrom) { Var(name=text) Lit(value="\"") Var(name=valueStart) } }
                If {
                  Call(target=findNotFound) { Var(name=valueEnd) }
                  Block { Return { Lit(value="") } }
                  Block {
                    Return { Call(target=sys.str.substring) { Var(name=text) Var(name=valueStart) Call(target=sub) { Var(name=valueEnd) Var(name=valueStart) } } }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=numberValueAt) {
    Fn(params=text,token,start,n) {
      Block {
        If {
          Call(target=intLt) { Call(target=strLen) { Var(name=text) } Lit(value=1) }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=pos) { Call(target=nthPos) { Var(name=text) Var(name=token) Var(name=start) Var(name=n) } }
            If {
              Call(target=findNotFound) { Var(name=pos) }
              Block { Return { Lit(value="") } }
              Block {
                Let(name=valueStart) { Add { Var(name=pos) Call(target=strLen) { Var(name=token) } } }
                Let(name=commaPos) { Call(target=findFrom) { Var(name=text) Lit(value=",") Var(name=valueStart) } }
                Let(name=bracePos) { Call(target=findFrom) { Var(name=text) Lit(value="}") Var(name=valueStart) } }
                Let(name=bracketPos) { Call(target=findFrom) { Var(name=text) Lit(value="]") Var(name=valueStart) } }
                Let(name=end1) { Call(target=minPositive) { Var(name=commaPos) Var(name=bracePos) Call(target=strLen) { Var(name=text) } } }
                Let(name=end2) { Call(target=minPositive) { Var(name=end1) Var(name=bracketPos) Call(target=strLen) { Var(name=text) } } }
                Return { Call(target=sys.str.substring) { Var(name=text) Var(name=valueStart) Call(target=sub) { Var(name=end2) Var(name=valueStart) } } }
              }
            }
          }
        }
      }
    }
  }

  Let(name=geoLabelAt) {
    Fn(params=geoBody,index) {
      Block {
        Let(name=name) { Call(target=quotedValueAt) { Var(name=geoBody) Lit(value="\"name\":\"") Lit(value=0) Var(name=index) } }
        Let(name=admin) { Call(target=quotedValueAt) { Var(name=geoBody) Lit(value="\"admin1\":\"") Lit(value=0) Var(name=index) } }
        If {
          Eq { Var(name=name) Lit(value="") }
          Block { Return { Lit(value="") } }
          Block {
            If {
              Eq { Var(name=admin) Lit(value="") }
              Block { Return { Var(name=name) } }
              Block { Return { StrConcat { Var(name=name) StrConcat { Lit(value=", ") Var(name=admin) } } } }
            }
          }
        }
      }
    }
  }

  Let(name=geoLatAt) {
    Fn(params=geoBody,index) {
      Block { Return { Call(target=numberValueAt) { Var(name=geoBody) Lit(value="\"latitude\":") Lit(value=0) Var(name=index) } } }
    }
  }

  Let(name=geoLonAt) {
    Fn(params=geoBody,index) {
      Block { Return { Call(target=numberValueAt) { Var(name=geoBody) Lit(value="\"longitude\":") Lit(value=0) Var(name=index) } } }
    }
  }

  Let(name=csvNth) {
    Fn(params=listText,n) {
      Block {
        If {
          Eq { Var(name=n) Lit(value=1) }
          Block {
            Let(name=commaPos) { Call(target=findFrom) { Var(name=listText) Lit(value=",") Lit(value=0) } }
            If {
              Call(target=findNotFound) { Var(name=commaPos) }
              Block { Return { Var(name=listText) } }
              Block { Return { Call(target=sys.str.substring) { Var(name=listText) Lit(value=0) Var(name=commaPos) } } }
            }
          }
          Block {
            Let(name=commaPos) { Call(target=findFrom) { Var(name=listText) Lit(value=",") Lit(value=0) } }
            If {
              Call(target=findNotFound) { Var(name=commaPos) }
              Block { Return { Lit(value="") } }
              Block {
                Let(name=nextStart) { Add { Var(name=commaPos) Lit(value=1) } }
                Let(name=tail) { Call(target=sys.str.substring) { Var(name=listText) Var(name=nextStart) Call(target=sub) { Call(target=strLen) { Var(name=listText) } Var(name=nextStart) } } }
                Return { Call(target=csvNth) { Var(name=tail) Add { Var(name=n) Lit(value=-1) } } }
              }
            }
          }
        }
      }
    }
  }

  Let(name=stripQuotes) {
    Fn(params=text) {
      Block {
        Let(name=len) { Call(target=strLen) { Var(name=text) } }
        If {
          Call(target=intLt) { Var(name=len) Lit(value=2) }
          Block { Return { Var(name=text) } }
          Block {
            If {
              Eq { Call(target=sys.str.substring) { Var(name=text) Lit(value=0) Lit(value=1) } Lit(value="\"") }
              Block {
                Return {
                  Call(target=sys.str.substring) {
                    Var(name=text)
                    Lit(value=1)
                    Add { Var(name=len) Lit(value=-2) }
                  }
                }
              }
              Block { Return { Var(name=text) } }
            }
          }
        }
      }
    }
  }

  Let(name=arrayListForKey) {
    Fn(params=json,key,start) {
      Block {
        Let(name=keyPos) { Call(target=findFrom) { Var(name=json) Var(name=key) Var(name=start) } }
        If {
          Call(target=findNotFound) { Var(name=keyPos) }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=listStart) { Add { Var(name=keyPos) Call(target=strLen) { Var(name=key) } } }
            Let(name=listEnd) { Call(target=findFrom) { Var(name=json) Lit(value="]") Var(name=listStart) } }
            If {
              Call(target=findNotFound) { Var(name=listEnd) }
              Block { Return { Lit(value="") } }
              Block { Return { Call(target=sys.str.substring) { Var(name=json) Var(name=listStart) Call(target=sub) { Var(name=listEnd) Var(name=listStart) } } } }
            }
          }
        }
      }
    }
  }

  Let(name=weatherCodeText) {
    Fn(params=code) {
      Block {
        Return {
          If { Eq { Var(name=code) Lit(value="0") } Block { Lit(value="Clear") } Block {
            If { Eq { Var(name=code) Lit(value="1") } Block { Lit(value="Mainly clear") } Block {
              If { Eq { Var(name=code) Lit(value="2") } Block { Lit(value="Partly cloudy") } Block {
                If { Eq { Var(name=code) Lit(value="3") } Block { Lit(value="Cloudy") } Block {
                  If { Eq { Var(name=code) Lit(value="45") } Block { Lit(value="Fog") } Block {
                    If { Eq { Var(name=code) Lit(value="61") } Block { Lit(value="Rain") } Block {
                      If { Eq { Var(name=code) Lit(value="71") } Block { Lit(value="Snow") } Block { Lit(value="Weather") } }
                    } }
                  } }
                } }
              } }
            } }
          } }
        }
      }
    }
  }

  Let(name=fetchGeoPath) {
    Fn(params=query) {
      Block {
        Let(name=encoded) { Call(target=replaceSpaces) { Var(name=query) } }
        Return {
          StrConcat {
            Lit(value="/v1/search?name=")
            StrConcat { Var(name=encoded) Lit(value="&count=3&language=en&format=json") }
          }
        }
      }
    }
  }

  Let(name=fetchForecastPath) {
    Fn(params=lat,lon) {
      Block {
        Return {
          StrConcat {
            Lit(value="/v1/forecast?latitude=")
            StrConcat {
              Var(name=lat)
              StrConcat {
                Lit(value="&longitude=")
                StrConcat {
                  Var(name=lon)
                  Lit(value="&current=temperature_2m,weather_code&daily=temperature_2m_max,temperature_2m_min&timezone=auto&forecast_days=5")
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=startHttpGet) {
    Fn(params=host,path) {
      Block {
        Return {
          Call(target=startHttpGetWithHeaders) {
            Var(name=host)
            Var(name=path)
            Lit(value="User-Agent: AiVectraWeather\\r\\nAccept: application/json\\r\\nConnection: close")
            Lit(value=65536)
          }
        }
      }
    }
  }

  Let(name=startHttpGetWithHeaders) {
    Fn(params=host,path,headers,maxBytes) {
      Block {
        Return {
          Call(target=httpRequest) {
            Lit(value="GET")
            Var(name=host)
            Lit(value=443)
            Var(name=path)
            Var(name=headers)
            Lit(value="")
            Var(name=maxBytes)
          }
        }
      }
    }
  }

  Let(name=startGeoRequest) {
    Fn(params=query) {
      Block {
        Return { Call(target=startHttpGet) { Lit(value="geocoding-api.open-meteo.com") Call(target=fetchGeoPath) { Var(name=query) } } }
      }
    }
  }

  Let(name=startForecastRequest) {
    Fn(params=lat,lon) {
      Block {
        Return { Call(target=startHttpGet) { Lit(value="api.open-meteo.com") Call(target=fetchForecastPath) { Var(name=lat) Var(name=lon) } } }
      }
    }
  }

  Let(name=startRadarMetaRequest) {
    Fn(params=_) {
      Block {
        Return {
          Call(target=startHttpGetWithHeaders) {
            Lit(value="api.rainviewer.com")
            Lit(value="/public/weather-maps.json")
            Lit(value="User-Agent: AiVectraWeather\\r\\nAccept: application/json\\r\\nConnection: close")
            Lit(value=131072)
          }
        }
      }
    }
  }

  Let(name=stripHttpsPrefix) {
    Fn(params=text) {
      Block {
        If {
          Call(target=contains) { Var(name=text) Lit(value="https://") }
          Block {
            Return {
              Call(target=sys.str.substring) {
                Var(name=text)
                Lit(value=8)
                Add { Call(target=strLen) { Var(name=text) } Lit(value=-8) }
              }
            }
          }
          Block { Return { Var(name=text) } }
        }
      }
    }
  }

  Let(name=lastQuotedValueAt) {
    Fn(params=text,token,start,index,last) {
      Block {
        Let(name=value) { Call(target=quotedValueAt) { Var(name=text) Var(name=token) Var(name=start) Var(name=index) } }
        If {
          Eq { Var(name=value) Lit(value="") }
          Block { Return { Var(name=last) } }
          Block {
            Return {
              Call(target=lastQuotedValueAt) {
                Var(name=text)
                Var(name=token)
                Var(name=start)
                Add { Var(name=index) Lit(value=1) }
                Var(name=value)
              }
            }
          }
        }
      }
    }
  }

  Let(name=rainViewerHost) {
    Fn(params=metaBody) {
      Block { Return { Call(target=quotedValueAt) { Var(name=metaBody) Lit(value="\"host\":\"") Lit(value=0) Lit(value=1) } } }
    }
  }

  Let(name=rainViewerLatestPath) {
    Fn(params=metaBody) {
      Block {
        Let(name=pastStart) { Call(target=findFrom) { Var(name=metaBody) Lit(value="\"past\":[") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=pastStart) }
          Block { Return { Lit(value="") } }
          Block {
            Return {
              Call(target=lastQuotedValueAt) {
                Var(name=metaBody)
                Lit(value="\"path\":\"")
                Var(name=pastStart)
                Lit(value=1)
                Lit(value="")
              }
            }
          }
        }
      }
    }
  }

  Let(name=rainViewerTilePath) {
    Fn(params=metaBody,lat,lon) {
      Block {
        Let(name=hostText) { Call(target=rainViewerHost) { Var(name=metaBody) } }
        Let(name=pathText) { Call(target=rainViewerLatestPath) { Var(name=metaBody) } }
        If {
          Eq { Var(name=hostText) Lit(value="") }
          Block { Return { Lit(value="") } }
          Block {
            If {
              Eq { Var(name=pathText) Lit(value="") }
              Block { Return { Lit(value="") } }
              Block {
                Return {
                  StrConcat {
                    Var(name=pathText)
                    StrConcat {
                      Lit(value="/256/7/")
                      StrConcat {
                        Var(name=lat)
                        StrConcat {
                          Lit(value="/")
                          StrConcat {
                            Var(name=lon)
                            Lit(value="/2/1_1.png")
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=startRadarFrameRequest) {
    Fn(params=metaBody,lat,lon) {
      Block {
        Let(name=hostText) { Call(target=stripHttpsPrefix) { Call(target=rainViewerHost) { Var(name=metaBody) } } }
        Let(name=pathText) { Call(target=rainViewerTilePath) { Var(name=metaBody) Var(name=lat) Var(name=lon) } }
        If {
          Eq { Var(name=hostText) Lit(value="") }
          Block { Return { Call(target=emptyNode) { Lit(value=0) } } }
          Block {
            If {
              Eq { Var(name=pathText) Lit(value="") }
              Block { Return { Call(target=emptyNode) { Lit(value=0) } } }
              Block {
                Return {
                  Call(target=startHttpGetWithHeaders) {
                    Var(name=hostText)
                    Var(name=pathText)
                    Lit(value="User-Agent: AiVectraWeather\\r\\nAccept: image/png,image/*\\r\\nConnection: close")
                    Lit(value=262144)
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=nonEmpty) {
    Fn(params=text) {
      Block {
        If {
          Eq { Var(name=text) Lit(value="") }
          Block { Return { Lit(value=false) } }
          Block { Return { Lit(value=true) } }
        }
      }
    }
  }

  Let(name=httpErrorDisplay) {
    Fn(params=errorCode) {
      Block {
        If {
          Eq { Var(name=errorCode) Lit(value="timeout") }
          Block { Return { Lit(value="request timed out") } }
          Block { Return { Var(name=errorCode) } }
        }
      }
    }
  }

  Let(name=forecastLineAt) {
    Fn(params=summary,index) {
      Block {
        If {
          Eq { Var(name=index) Lit(value=1) }
          Block {
            Let(name=breakPos) { Call(target=findFrom) { Var(name=summary) Lit(value="\n") Lit(value=0) } }
            If {
              Call(target=findNotFound) { Var(name=breakPos) }
              Block { Return { Var(name=summary) } }
              Block { Return { Call(target=sys.str.substring) { Var(name=summary) Lit(value=0) Var(name=breakPos) } } }
            }
          }
          Block {
            Let(name=breakPos) { Call(target=findFrom) { Var(name=summary) Lit(value="\n") Lit(value=0) } }
            If {
              Call(target=findNotFound) { Var(name=breakPos) }
              Block { Return { Lit(value="") } }
              Block {
                Let(name=nextStart) { Add { Var(name=breakPos) Lit(value=1) } }
                Let(name=tail) {
                  Call(target=sys.str.substring) {
                    Var(name=summary)
                    Var(name=nextStart)
                    Call(target=sub) { Call(target=strLen) { Var(name=summary) } Var(name=nextStart) }
                  }
                }
                Return { Call(target=forecastLineAt) { Var(name=tail) Add { Var(name=index) Lit(value=-1) } } }
              }
            }
          }
        }
      }
    }
  }

  Let(name=currentLineFromForecastRaw) {
    Fn(params=forecastBody) {
      Block {
        Let(name=currentStart) { Call(target=findFrom) { Var(name=forecastBody) Lit(value="\"current\":{") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=currentStart) }
          Block { Return { Lit(value="Now: unavailable") } }
          Block {
            Let(name=temp) { Call(target=numberValueAt) { Var(name=forecastBody) Lit(value="\"temperature_2m\":") Var(name=currentStart) Lit(value=1) } }
            Let(name=code) { Call(target=numberValueAt) { Var(name=forecastBody) Lit(value="\"weather_code\":") Var(name=currentStart) Lit(value=1) } }
            Return {
              StrConcat {
                Lit(value="Now: ")
                StrConcat { Var(name=temp) StrConcat { Lit(value=" C  ") Call(target=weatherCodeText) { Var(name=code) } } }
              }
            }
          }
        }
      }
    }
  }

  Let(name=dayLineFromForecastRaw) {
    Fn(params=forecastBody,dayIndex) {
      Block {
        Let(name=dailyStart) { Call(target=findFrom) { Var(name=forecastBody) Lit(value="\"daily\":{") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=dailyStart) }
          Block { Return { Lit(value="--") } }
          Block {
            Let(name=maxList) { Call(target=arrayListForKey) { Var(name=forecastBody) Lit(value="\"temperature_2m_max\":[") Var(name=dailyStart) } }
            Let(name=minList) { Call(target=arrayListForKey) { Var(name=forecastBody) Lit(value="\"temperature_2m_min\":[") Var(name=dailyStart) } }
            Let(name=maxVal) { Call(target=csvNth) { Var(name=maxList) Var(name=dayIndex) } }
            Let(name=minVal) { Call(target=csvNth) { Var(name=minList) Var(name=dayIndex) } }
            Return {
              StrConcat {
                Lit(value="D")
                StrConcat {
                  ToString { Var(name=dayIndex) }
                  StrConcat { Lit(value=": ") StrConcat { Var(name=maxVal) StrConcat { Lit(value="/") StrConcat { Var(name=minVal) Lit(value=" C") } } } }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=encodeForecastSummary) {
    Fn(params=forecastBody) {
      Block {
        Return {
          StrConcat {
            Call(target=currentLineFromForecastRaw) { Var(name=forecastBody) }
            StrConcat {
              Lit(value="\n")
              StrConcat {
                Call(target=dayLineFromForecastRaw) { Var(name=forecastBody) Lit(value=1) }
                StrConcat {
                  Lit(value="\n")
                  StrConcat {
                    Call(target=dayLineFromForecastRaw) { Var(name=forecastBody) Lit(value=2) }
                    StrConcat {
                      Lit(value="\n")
                      StrConcat {
                        Call(target=dayLineFromForecastRaw) { Var(name=forecastBody) Lit(value=3) }
                        StrConcat {
                          Lit(value="\n")
                          StrConcat {
                            Call(target=dayLineFromForecastRaw) { Var(name=forecastBody) Lit(value=4) }
                            StrConcat {
                              Lit(value="\n")
                              Call(target=dayLineFromForecastRaw) { Var(name=forecastBody) Lit(value=5) }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=currentLineFromForecast) {
    Fn(params=forecastBody) {
      Block {
        If {
          Call(target=contains) { Var(name=forecastBody) Lit(value="\"current\":{") }
          Block { Return { Call(target=currentLineFromForecastRaw) { Var(name=forecastBody) } } }
          Block { Return { Call(target=forecastLineAt) { Var(name=forecastBody) Lit(value=1) } } }
        }
      }
    }
  }

  Let(name=dayLineFromForecast) {
    Fn(params=forecastBody,dayIndex) {
      Block {
        If {
          Call(target=contains) { Var(name=forecastBody) Lit(value="\"daily\":{") }
          Block { Return { Call(target=dayLineFromForecastRaw) { Var(name=forecastBody) Var(name=dayIndex) } } }
          Block { Return { Call(target=forecastLineAt) { Var(name=forecastBody) Add { Var(name=dayIndex) Lit(value=1) } } } }
        }
      }
    }
  }

  Let(name=forecastDayLabel) {
    Fn(params=dayIndex) {
      Block {
        Return {
          If { Eq { Var(name=dayIndex) Lit(value=1) } Block { Lit(value="Today") } Block {
            If { Eq { Var(name=dayIndex) Lit(value=2) } Block { Lit(value="Tomorrow") } Block {
              If { Eq { Var(name=dayIndex) Lit(value=3) } Block { Lit(value="Day 3") } Block {
                If { Eq { Var(name=dayIndex) Lit(value=4) } Block { Lit(value="Day 4") } Block { Lit(value="Day 5") } }
              } }
            } }
          } }
        }
      }
    }
  }

  Let(name=forecastDateLabelFromRaw) {
    Fn(params=forecastBody,dayIndex) {
      Block {
        Let(name=dailyStart) { Call(target=findFrom) { Var(name=forecastBody) Lit(value="\"daily\":{") Lit(value=0) } }
        If {
          Call(target=findNotFound) { Var(name=dailyStart) }
          Block { Return { Call(target=forecastDayLabel) { Var(name=dayIndex) } } }
          Block {
            Let(name=timeList) { Call(target=arrayListForKey) { Var(name=forecastBody) Lit(value="\"time\":[") Var(name=dailyStart) } }
            Let(name=rawDate) { Call(target=csvNth) { Var(name=timeList) Var(name=dayIndex) } }
            Let(name=dateValue) { Call(target=stripQuotes) { Var(name=rawDate) } }
            If {
              Call(target=intLt) { Call(target=strLen) { Var(name=dateValue) } Lit(value=10) }
              Block { Return { Call(target=forecastDayLabel) { Var(name=dayIndex) } } }
              Block {
                If {
                  Eq { Var(name=dayIndex) Lit(value=1) }
                  Block { Return { Lit(value="Today") } }
                  Block {
                    If {
                      Eq { Var(name=dayIndex) Lit(value=2) }
                      Block { Return { Lit(value="Tomorrow") } }
                      Block {
                        Return {
                          StrConcat {
                            Call(target=sys.str.substring) { Var(name=dateValue) Lit(value=5) Lit(value=2) }
                            StrConcat {
                              Lit(value="/")
                              Call(target=sys.str.substring) { Var(name=dateValue) Lit(value=8) Lit(value=2) }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let(name=forecastDayLabelForBody) {
    Fn(params=forecastBody,dayIndex) {
      Block {
        If {
          Call(target=contains) { Var(name=forecastBody) Lit(value="\"daily\":{") }
          Block { Return { Call(target=forecastDateLabelFromRaw) { Var(name=forecastBody) Var(name=dayIndex) } } }
          Block { Return { Call(target=forecastDayLabel) { Var(name=dayIndex) } } }
        }
      }
    }
  }

  Let(name=currentTemperatureText) {
    Fn(params=forecastBody) {
      Block {
