                  If { Call(target=contains) { Var(name=statusLine) Lit(value="unavailable") } Block { Lit(value="#f59e0b") } Block {
                    If { Call(target=contains) { Var(name=statusLine) Lit(value="No ") } Block { Lit(value="#f59e0b") } Block { Lit(value="#34d399") } }
                  } }
