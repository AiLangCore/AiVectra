  Let(name=render) {
    Fn(params=handle,query,focused,dropdownOpen,geoBody,selectedLabel,forecastBody,statusLine,radarOpen,radarTick,radarImageRgba,netKind,w,h,submitFlash,caretVisible) {
      Block {
        Let(name=radarX) { Add { Var(name=w) Lit(value=-178) } }
        Let(name=entryW) { Add { Var(name=radarX) Lit(value=-70) } }
        Let(name=submitX) { Add { Lit(value=52) Add { Var(name=entryW) Lit(value=-42) } } }
        Let(name=dropdownCount) {
          If {
            Call(target=intLt) { Call(target=strLen) { Var(name=geoBody) } Lit(value=1) }
            Block { Lit(value=0) }
            Block {
              Let(name=count1) {
                If {
                  Eq { Call(target=geoLabelAt) { Var(name=geoBody) Lit(value=1) } Lit(value="") }
                  Block { Lit(value=0) }
                  Block { Lit(value=1) }
                }
              }
              Let(name=count2) {
                If {
                  Eq { Call(target=geoLabelAt) { Var(name=geoBody) Lit(value=2) } Lit(value="") }
                  Block { Var(name=count1) }
                  Block { Add { Var(name=count1) Lit(value=1) } }
                }
              }
              If {
                Eq { Call(target=geoLabelAt) { Var(name=geoBody) Lit(value=3) } Lit(value="") }
                Block { Var(name=count2) }
                Block { Add { Var(name=count2) Lit(value=1) } }
              }
            }
          }
        }

        Call(target=frameBegin) { Var(name=handle) }
        Call(target=frameRect) { Var(name=handle) Lit(value=0) Lit(value=0) Var(name=w) Var(name=h) Lit(value="#07111f") }
        Call(target=frameRect) { Var(name=handle) Lit(value=0) Lit(value=0) Var(name=w) Lit(value=140) Lit(value="#0c1a2f") }
        Call(target=frameRect) { Var(name=handle) Lit(value=18) Lit(value=18) Add { Var(name=w) Lit(value=-36) } Add { Var(name=h) Lit(value=-36) } Lit(value="#0b1626") }
        Call(target=frameRect) { Var(name=handle) Lit(value=34) Lit(value=34) Add { Var(name=w) Lit(value=-68) } Lit(value=142) Lit(value="#11243b") }
        Call(target=frameRect) { Var(name=handle) Lit(value=34) Lit(value=194) Add { Var(name=w) Lit(value=-68) } Lit(value=132) Lit(value="#0f1c2f") }
        Call(target=frameRect) { Var(name=handle) Lit(value=34) Lit(value=344) Add { Var(name=w) Lit(value=-68) } Lit(value=132) Lit(value="#0f1c2f") }
        Call(target=frameRect) { Var(name=handle) Lit(value=34) Lit(value=494) Add { Var(name=w) Lit(value=-68) } Lit(value=72) Lit(value="#0f1c2f") }
        Call(target=frameRect) { Var(name=handle) Lit(value=34) Add { Var(name=h) Lit(value=-74) } Add { Var(name=w) Lit(value=-68) } Lit(value=28) Lit(value="#10243a") }
        Call(target=frameRect) { Var(name=handle) Lit(value=52) Lit(value=223) Lit(value=166) Lit(value=76) Lit(value="#15304b") }
        Call(target=frameRect) { Var(name=handle) Lit(value=236) Lit(value=223) Add { Var(name=w) Lit(value=-288) } Lit(value=76) Lit(value="#12253c") }
        Call(target=frameRect) { Var(name=handle) Lit(value=52) Lit(value=392) Add { Var(name=w) Lit(value=-104) } Lit(value=26) Lit(value="#11243b") }

        Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=48) Lit(value="Weather") Lit(value="#f8fafc") Lit(value=28) }
        Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=76) Lit(value="Search by ZIP, city, or city,state") Lit(value="#a5b4c7") Lit(value=14) }
        Call(target=frameText) {
          Var(name=handle)
          Lit(value=52)
          Lit(value=154)
          If { Eq { Var(name=selectedLabel) Lit(value="") } Block { Lit(value="No location loaded yet") } Block { StrConcat { Lit(value="Tracking ") Var(name=selectedLabel) } } }
          Lit(value="#dbe7f5")
          Lit(value=15)
        }
        Call(target=frameText) {
          Var(name=handle)
          Lit(value=52)
          Lit(value=216)
          Lit(value="Current Conditions")
          Lit(value="#dbe7f5")
          Lit(value=16)
        }
        Call(target=frameText) {
          Var(name=handle)
          Lit(value=52)
          Lit(value=366)
          Lit(value="5-Day Outlook")
          Lit(value="#dbe7f5")
          Lit(value=16)
        }

        Call(target=interactiveVectorState) {
          Var(name=handle) Lit(value=52) Lit(value=94) Var(name=entryW) Lit(value=48)
          If { Eq { Var(name=focused) Lit(value=true) } Block { Lit(value="focused") } Block { Lit(value="normal") } }
          Lit(value="rect") Lit(value="") Lit(value="#081320") Lit(value="#0b1320") Lit(value="#0d1726") Lit(value="#173052") Lit(value="#081320")
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=68) Lit(value=108)
          If { Eq { Var(name=query) Lit(value="") } Block { Lit(value="Enter a ZIP code or city name") } Block { Var(name=query) } }
          If { Eq { Var(name=query) Lit(value="") } Block { Lit(value="#71839a") } Block { Lit(value="#f8fafc") } }
          Lit(value=18)
        }
        Call(target=interactiveVectorState) {
          Var(name=handle) Var(name=submitX) Lit(value=100) Lit(value=36) Lit(value=36)
          If { Eq { Var(name=netKind) Lit(value="") } Block { Lit(value="normal") } Block { Lit(value="disabled") } }
          Lit(value="rect") Lit(value="")
          Lit(value="#16314e") Lit(value="#28547f") Lit(value="#1f4265") Lit(value="#24527b") Lit(value="#425569")
        }
        If {
          Eq { Var(name=netKind) Lit(value="") }
          Block {
            Call(target=frameEllipse) { Var(name=handle) Add { Var(name=submitX) Lit(value=9) } Lit(value=108) Lit(value=12) Lit(value=12) Lit(value="#dbeafe") }
            Call(target=frameLine) { Var(name=handle) Add { Var(name=submitX) Lit(value=20) } Lit(value=119) Add { Var(name=submitX) Lit(value=27) } Lit(value=126) Lit(value="#dbeafe") Lit(value=2) }
          }
          Block {
            Call(target=frameEllipse) { Var(name=handle) Add { Var(name=submitX) Lit(value=8) } Lit(value=112) Lit(value=6) Lit(value=6) Lit(value="#93c5fd") }
            Call(target=frameEllipse) { Var(name=handle) Add { Var(name=submitX) Lit(value=16) } Lit(value=112) Lit(value=6) Lit(value=6) Lit(value="#93c5fd") }
            Call(target=frameEllipse) { Var(name=handle) Add { Var(name=submitX) Lit(value=24) } Lit(value=112) Lit(value=6) Lit(value=6) Lit(value="#93c5fd") }
          }
        }
        If {
          Eq { Var(name=focused) Lit(value=true) }
          Block {
            If {
              Eq { Var(name=caretVisible) Lit(value=true) }
              Block {
                Call(target=frameRect) {
                  Var(name=handle)
                  Add { Lit(value=68) Call(target=mul) { Lit(value=11) Call(target=strLen) { Var(name=query) } Lit(value=0) } }
                  Lit(value=106) Lit(value=2) Lit(value=22) Lit(value="#dbeafe")
                }
                Lit(value=0)
              }
              Block { Lit(value=0) }
            }
            Lit(value=0)
          }
          Block { Lit(value=0) }
        }

        Call(target=interactiveVectorState) {
          Var(name=handle) Var(name=radarX) Lit(value=46) Lit(value=126) Lit(value=34)
          If { Eq { Var(name=radarOpen) Lit(value=true) } Block { Lit(value="pressed") } Block { Lit(value="normal") } }
          Lit(value="rect") Lit(value="")
          Lit(value="#13283f") Lit(value="#27496b") Lit(value="#1b3754") Lit(value="#10253a") Lit(value="#223244")
        }
        Call(target=frameText) {
          Var(name=handle)
          Add { Var(name=radarX) Lit(value=16) }
          Lit(value=67)
          If { Eq { Var(name=radarOpen) Lit(value=true) } Block { Lit(value="Hide Radar") } Block { Lit(value="Open Radar") } }
          Lit(value="#dbeafe")
          Lit(value=14)
        }

        If {
          Eq { Var(name=dropdownOpen) Lit(value=true) }
          Block {
            Call(target=interactiveVectorState) {
              Var(name=handle) Lit(value=52) Lit(value=148) Var(name=entryW)
              Add { Lit(value=12) Call(target=mul) { Lit(value=34) Var(name=dropdownCount) Lit(value=0) } }
              Lit(value="normal") Lit(value="rect") Lit(value="") Lit(value="#0f1b2d") Lit(value="#0f1b2d") Lit(value="#22364f") Lit(value="#0f1b2d") Lit(value="#0a1220")
            }
            If { Call(target=intGte) { Var(name=dropdownCount) Lit(value=1) } Block { Call(target=frameText) { Var(name=handle) Lit(value=70) Lit(value=158) Call(target=geoLabelAt) { Var(name=geoBody) Lit(value=1) } Lit(value="#e2e8f0") Lit(value=16) } Lit(value=0) } Block { Lit(value=0) } }
            If { Call(target=intGte) { Var(name=dropdownCount) Lit(value=2) } Block { Call(target=frameLine) { Var(name=handle) Lit(value=66) Lit(value=180) Add { Lit(value=52) Var(name=entryW) } Lit(value=180) Lit(value="#22364f") Lit(value=1) } Call(target=frameText) { Var(name=handle) Lit(value=70) Lit(value=192) Call(target=geoLabelAt) { Var(name=geoBody) Lit(value=2) } Lit(value="#e2e8f0") Lit(value=16) } Lit(value=0) } Block { Lit(value=0) } }
            If { Call(target=intGte) { Var(name=dropdownCount) Lit(value=3) } Block { Call(target=frameLine) { Var(name=handle) Lit(value=66) Lit(value=214) Add { Lit(value=52) Var(name=entryW) } Lit(value=214) Lit(value="#22364f") Lit(value=1) } Call(target=frameText) { Var(name=handle) Lit(value=70) Lit(value=226) Call(target=geoLabelAt) { Var(name=geoBody) Lit(value=3) } Lit(value="#e2e8f0") Lit(value=16) } Lit(value=0) } Block { Lit(value=0) } }
            Lit(value=0)
          }
          Block { Lit(value=0) }
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=68) Lit(value=232)
          Lit(value="Temperature")
          Lit(value="#9fb4ca") Lit(value=12)
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=68) Lit(value=248)
          If { Eq { Var(name=forecastBody) Lit(value="") } Block { Lit(value="--") } Block { Call(target=currentTemperatureText) { Var(name=forecastBody) } } }
          Lit(value="#f8fafc") Lit(value=26)
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=68) Lit(value=278)
          If { Eq { Var(name=forecastBody) Lit(value="") } Block { Lit(value="Awaiting forecast data") } Block { Call(target=currentConditionText) { Var(name=forecastBody) } } }
          Lit(value="#d8e3f0") Lit(value=16)
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=252) Lit(value=232)
          Lit(value="Overview")
          Lit(value="#9fb4ca") Lit(value=12)
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=252) Lit(value=250)
          If { Eq { Var(name=selectedLabel) Lit(value="") } Block { Lit(value="No active location selected.") } Block { StrConcat { Lit(value="Active location: ") Var(name=selectedLabel) } } }
          Lit(value="#eef4fb") Lit(value=15)
        }
        Call(target=frameText) {
          Var(name=handle) Lit(value=252) Lit(value=274)
          If { Eq { Var(name=forecastBody) Lit(value="") } Block { Lit(value="Run a search to populate current conditions and the daily outlook.") } Block { Lit(value="Forecast text is reduced into a stable summary so the sample stays deterministic and lightweight.") } }
          Lit(value="#b7cadc") Lit(value=13)
        }

        If {
          Eq { Var(name=forecastBody) Lit(value="") }
          Block {
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=316) Lit(value="No forecast loaded yet.") Lit(value="#7f93aa") Lit(value=14) }
            Lit(value=0)
          }
          Block {
            Call(target=frameText) { Var(name=handle) Lit(value=68) Lit(value=410) Lit(value="Day") Lit(value="#8fb7d9") Lit(value=12) }
            Call(target=frameText) { Var(name=handle) Lit(value=156) Lit(value=410) Lit(value="High / Low") Lit(value="#8fb7d9") Lit(value=12) }
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=394) Call(target=forecastDayLabelForBody) { Var(name=forecastBody) Lit(value=1) } Lit(value="#8fb7d9") Lit(value=13) }
            Call(target=frameText) { Var(name=handle) Lit(value=156) Lit(value=392) Call(target=dayLineFromForecast) { Var(name=forecastBody) Lit(value=1) } Lit(value="#eef4fb") Lit(value=15) }
            Call(target=frameLine) { Var(name=handle) Lit(value=52) Lit(value=406) Add { Var(name=w) Lit(value=-52) } Lit(value=406) Lit(value="#22364f") Lit(value=1) }
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=424) Call(target=forecastDayLabelForBody) { Var(name=forecastBody) Lit(value=2) } Lit(value="#8fb7d9") Lit(value=13) }
            Call(target=frameText) { Var(name=handle) Lit(value=156) Lit(value=422) Call(target=dayLineFromForecast) { Var(name=forecastBody) Lit(value=2) } Lit(value="#eef4fb") Lit(value=15) }
            Call(target=frameLine) { Var(name=handle) Lit(value=52) Lit(value=436) Add { Var(name=w) Lit(value=-52) } Lit(value=436) Lit(value="#22364f") Lit(value=1) }
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=454) Call(target=forecastDayLabelForBody) { Var(name=forecastBody) Lit(value=3) } Lit(value="#8fb7d9") Lit(value=13) }
            Call(target=frameText) { Var(name=handle) Lit(value=156) Lit(value=452) Call(target=dayLineFromForecast) { Var(name=forecastBody) Lit(value=3) } Lit(value="#eef4fb") Lit(value=15) }
            Call(target=frameLine) { Var(name=handle) Lit(value=52) Lit(value=466) Add { Var(name=w) Lit(value=-52) } Lit(value=466) Lit(value="#22364f") Lit(value=1) }
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=484) Call(target=forecastDayLabelForBody) { Var(name=forecastBody) Lit(value=4) } Lit(value="#8fb7d9") Lit(value=13) }
            Call(target=frameText) { Var(name=handle) Lit(value=156) Lit(value=482) Call(target=dayLineFromForecast) { Var(name=forecastBody) Lit(value=4) } Lit(value="#eef4fb") Lit(value=15) }
            Call(target=frameLine) { Var(name=handle) Lit(value=52) Lit(value=496) Add { Var(name=w) Lit(value=-52) } Lit(value=496) Lit(value="#22364f") Lit(value=1) }
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=514) Call(target=forecastDayLabelForBody) { Var(name=forecastBody) Lit(value=5) } Lit(value="#8fb7d9") Lit(value=13) }
            Call(target=frameText) { Var(name=handle) Lit(value=156) Lit(value=512) Call(target=dayLineFromForecast) { Var(name=forecastBody) Lit(value=5) } Lit(value="#eef4fb") Lit(value=15) }
            Lit(value=0)
          }
        }
        Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=520) Lit(value="Radar / Maps") Lit(value="#eef4fb") Lit(value=16) }
        If {
          Eq { Var(name=radarOpen) Lit(value=true) }
          Block {
            Call(target=frameRect) { Var(name=handle) Lit(value=48) Lit(value=104) Add { Var(name=w) Lit(value=-96) } Add { Var(name=h) Lit(value=-168) } Lit(value="#07111fde") }
            Call(target=interactiveVectorState) {
              Var(name=handle) Lit(value=88) Lit(value=128)
              Add { Var(name=w) Lit(value=-176) }
              Add { Var(name=h) Lit(value=-236) }
              Lit(value="normal") Lit(value="rect") Lit(value="") Lit(value="#081320") Lit(value="#081320") Lit(value="#2c4868") Lit(value="#081320") Lit(value="#040812")
            }
            Call(target=frameText) { Var(name=handle) Lit(value=108) Lit(value=154) Lit(value="Radar") Lit(value="#eef4fb") Lit(value=18) }
            Call(target=frameText) { Var(name=handle) Add { Var(name=w) Lit(value=-228) } Lit(value=154) Lit(value="Live image") Lit(value="#8fb7d9") Lit(value=13) }
            If {
              Eq { Var(name=radarImageRgba) Lit(value="") }
              Block {
                Call(target=frameText) { Var(name=handle) Lit(value=108) Lit(value=188) Lit(value="Loading radar image...") Lit(value="#c5d5e6") Lit(value=15) }
                Call(target=frameText) { Var(name=handle) Lit(value=108) Lit(value=212) Lit(value="WeatherApp now has image decode support on macOS; this panel will render the latest fetched frame once available.") Lit(value="#8fb7d9") Lit(value=13) }
                Lit(value=0)
              }
              Block {
                Call(target=frameImage) {
                  Var(name=handle)
                  Lit(value=108)
                  Lit(value=178)
                  Add { Var(name=w) Lit(value=-216) }
                  Add { Var(name=h) Lit(value=-286) }
                  Var(name=radarImageRgba)
                }
                Lit(value=0)
              }
            }
            Lit(value=0)
          }
          Block {
            Call(target=frameText) { Var(name=handle) Lit(value=52) Lit(value=542) Lit(value="Open the radar panel to load an in-app radar image.") Lit(value="#c5d5e6") Lit(value=14) }
            Lit(value=0)
          }
        }

        Call(target=frameRect) { Var(name=handle) Lit(value=40) Add { Var(name=h) Lit(value=-66) } Lit(value=4) Lit(value=18) Call(target=statusAccent) { Var(name=statusLine) } }
        Call(target=frameText) { Var(name=handle) Lit(value=52) Add { Var(name=h) Lit(value=-68) } Lit(value="Status") Lit(value="#9fb4ca") Lit(value=11) }
        Call(target=frameText) { Var(name=handle) Lit(value=52) Add { Var(name=h) Lit(value=-54) } Var(name=statusLine) Lit(value="#eef4fb") Lit(value=13) }
        Call(target=framePresent) { Var(name=handle) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=isBackKey) {
    Fn(params=keyName) {
      Block { Return { Eq { Call(target=debugControlName) { Var(name=keyName) } Lit(value="backspace") } } }
    }
  }

  Let(name=isEnterEvent) {
    Fn(params=keyName,textValue) {
      Block {
        If {
          Eq { Call(target=debugControlName) { Var(name=keyName) } Lit(value="enter") }
          Block { Return { Lit(value=true) } }
          Block { Return { Eq { Var(name=textValue) Lit(value="\r") } } }
        }
      }
    }
  }

  Let(name=inputCharFromEvent) {
    Fn(params=keyName,textValue) {
      Block {
        If {
          Eq { Var(name=textValue) Lit(value="") }
          Block { Return { Call(target=keyToText) { Var(name=keyName) } } }
          Block { Return { Var(name=textValue) } }
        }
      }
    }
  }

  Let(name=weatherRemoveLastChar) {
    Fn(params=textValue) {
      Block {
        If {
          Eq { Var(name=textValue) Lit(value="") }
          Block { Return { Lit(value="") } }
          Block {
            Let(name=len) { Call(target=strLen) { Var(name=textValue) } }
            Return {
              Call(target=sys.str.substring) {
                Var(name=textValue)
                Lit(value=0)
                Call(target=sub) { Var(name=len) Lit(value=1) }
              }
            }
          }
        }
      }
    }
  }

  Let(name=isForbiddenInputChar) {
    Fn(params=textValue) {
      Block {
        If { Eq { Var(name=textValue) Lit(value="	") } Block { Return { Lit(value=true) } } Block {
          If { Eq { Var(name=textValue) Lit(value="
") } Block { Return { Lit(value=true) } } Block {
            If { Eq { Var(name=textValue) Lit(value="
") } Block { Return { Lit(value=true) } } Block { Return { Lit(value=false) } } }
          } }
        } }
      }
    }
  }

  Let(name=traceUiState) {
    Fn(params=debugLive,focused,dropdownOpen,radarOpen,query,selectedLabel,statusLine,entryW,submitX,w,h,submitFlash) {
      Block {
        Call(target=debugEmitUiIf) {
          Var(name=debugLive)
          Lit(value="state")
          If {
            Eq { Var(name=dropdownOpen) Lit(value=true) }
            Block {
              If {
                Eq { Var(name=radarOpen) Lit(value=true) }
                Block { Lit(value="dropdown+radar") }
                Block { Lit(value="dropdown") }
              }
            }
            Block {
              If {
                Eq { Var(name=radarOpen) Lit(value=true) }
                Block { Lit(value="radar") }
                Block { Lit(value="idle") }
              }
            }
          }
          Var(name=focused)
          Call(target=strLen) { Var(name=query) }
          Call(target=strLen) { Var(name=selectedLabel) }
          StrConcat { Lit(value="52,94,") StrConcat { ToString { Var(name=entryW) } Lit(value=",48") } }
          StrConcat { ToString { Var(name=submitX) } Lit(value=",100,36,36") }
        }
        Call(target=traceSceneFrame) {
          Var(name=debugLive)
          Var(name=w)
          Var(name=h)
          Var(name=query)
          Var(name=statusLine)
          Var(name=focused)
          Var(name=dropdownOpen)
          Var(name=radarOpen)
          Var(name=submitFlash)
        }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=traceEventToml) {
    Fn(params=debugLive,eventType,keyName,textValue,clickX,clickY) {
      Block { Return { Call(target=debugEmitEventIf) { Var(name=debugLive) Var(name=eventType) Var(name=keyName) Var(name=textValue) Var(name=clickX) Var(name=clickY) } } }
    }
  }

  Let(name=traceNetLine) {
    Fn(params=debugLive,phase,detailA,detailB) {
      Block { Return { Lit(value=0) } }
    }
  }

  Let(name=traceSceneNode) {
    Fn(params=debugLive,frame,order,id,kind,fill,textValue,fontSize,x,y,w,h) {
      Block {
        Return {
          Call(target=debugEmitSceneNodeIf) {
            Var(name=debugLive)
            Var(name=frame)
            Var(name=order)
            Var(name=id)
            Lit(value="root")
            Var(name=kind)
            Var(name=fill)
            Lit(value="")
            Lit(value=0)
            Var(name=textValue)
            Lit(value="")
            Var(name=fontSize)
            Var(name=x)
            Var(name=y)
            Var(name=w)
            Var(name=h)
            Lit(value="matrix(1,0,0,1,0,0)")
          }
        }
      }
    }
  }

  Let(name=traceSceneFrame) {
    Fn(params=debugLive,w,h,query,statusLine,focused,dropdownOpen,radarOpen,submitFlash) {
      Block {
        If {
          Eq { Var(name=debugLive) Lit(value=true) }
          Block {
            Let(name=radarX) { Add { Var(name=w) Lit(value=-178) } }
            Let(name=entryW) { Add { Var(name=radarX) Lit(value=-70) } }
            Let(name=submitX) { Add { Lit(value=52) Add { Var(name=entryW) Lit(value=-42) } } }
            Let(name=panelW) { Add { Var(name=w) Lit(value=-40) } }
            Let(name=panelH) { Add { Var(name=h) Lit(value=-40) } }
            Let(name=frameId) {
              Add { Var(name=w) Add { Var(name=h) Add { Call(target=strLen) { Var(name=query) } Call(target=strLen) { Var(name=statusLine) } } } }
            }
            Call(target=traceSceneNode) { Var(name=debugLive) Var(name=frameId) Lit(value=1) Lit(value="panel") Lit(value="Rect") Lit(value="#0f172a") Lit(value="") Lit(value=0) Lit(value=20) Lit(value=20) Var(name=panelW) Var(name=panelH) }
            Call(target=traceSceneNode) {
              Var(name=debugLive) Var(name=frameId) Lit(value=2) Lit(value="input")
              Lit(value="Rect")
              If { Eq { Var(name=focused) Lit(value=true) } Block { Lit(value="#172554") } Block { Lit(value="#0f172a") } }
              Lit(value="") Lit(value=0) Lit(value=52) Lit(value=94) Var(name=entryW) Lit(value=48)
            }
            Call(target=traceSceneNode) { Var(name=debugLive) Var(name=frameId) Lit(value=3) Lit(value="input_text") Lit(value="Text") Lit(value="#ffffff") Var(name=query) Lit(value=18) Lit(value=68) Lit(value=108) Lit(value=0) Lit(value=0) }
            Call(target=traceSceneNode) {
              Var(name=debugLive) Var(name=frameId) Lit(value=4) Lit(value="search_action")
              Lit(value="Rect")
              If { Call(target=intLt) { Lit(value=0) Var(name=submitFlash) } Block { Lit(value="#3b82f6") } Block { Lit(value="#2563eb") } }
              Lit(value="") Lit(value=0) Var(name=submitX) Lit(value=100) Lit(value=36) Lit(value=36)
            }
            Call(target=traceSceneNode) { Var(name=debugLive) Var(name=frameId) Lit(value=5) Lit(value="radar_toggle") Lit(value="Rect") Lit(value="#13283f") Lit(value="") Lit(value=0) Var(name=radarX) Lit(value=46) Lit(value=126) Lit(value=34) }
            Call(target=traceSceneNode) { Var(name=debugLive) Var(name=frameId) Lit(value=6) Lit(value="status") Lit(value="Text") Lit(value="#e2e8f0") Var(name=statusLine) Lit(value=14) Lit(value=40) Add { Var(name=h) Lit(value=-28) } Lit(value=0) Lit(value=0) }
            Return { Lit(value=0) }
          }
          Block { Return { Lit(value=0) } }
        }
      }
    }
  }

  Let(name=appInit) {
    Fn(params=args) {
      Block {
        Let(name=mode) { Call(target=appModeFromArgs) { Var(name=args) } }
        Return {
          Call(target=weatherState) {
            Lit(value="")
            Lit(value=true)
            Lit(value=false)
            Lit(value="")
            Lit(value="")
            Lit(value="")
            Lit(value="")
            Lit(value="")
            Lit(value="Ready. Enter location, then use Search.")
            Lit(value=false)
            Lit(value=0)
            Lit(value="")
            Lit(value=960)
            Lit(value=640)
            Lit(value=0)
            Lit(value=0)
            Lit(value="")
            Call(target=emptyNode) { Lit(value=0) }
            Lit(value=0)
            Call(target=debugModeSceneOrLive) { Var(name=mode) }
          }
        }
      }
    }
  }

  Let(name=appRender) {
    Fn(params=handle,state) {
      Block {
        Let(name=query) { Call(target=stateQuery) { Var(name=state) } }
        Let(name=focused) { Call(target=stateFocused) { Var(name=state) } }
        Let(name=dropdownOpen) { Call(target=stateDropdownOpen) { Var(name=state) } }
        Let(name=geoBody) { Call(target=stateGeoBody) { Var(name=state) } }
        Let(name=selectedLabel) { Call(target=stateSelectedLabel) { Var(name=state) } }
        Let(name=forecastBody) { Call(target=stateForecastBody) { Var(name=state) } }
        Let(name=statusLine) { Call(target=stateStatusLine) { Var(name=state) } }
        Let(name=radarOpen) { Call(target=stateRadarOpen) { Var(name=state) } }
        Let(name=radarTick) { Call(target=stateRadarTick) { Var(name=state) } }
        Let(name=radarImageRgba) { Call(target=stateRadarImageRgba) { Var(name=state) } }
        Let(name=netKind) { Call(target=stateNetKind) { Var(name=state) } }
        Let(name=lastW) { Call(target=stateLastW) { Var(name=state) } }
        Let(name=lastH) { Call(target=stateLastH) { Var(name=state) } }
        Let(name=submitFlash) { Call(target=stateSubmitFlash) { Var(name=state) } }
        Let(name=debugLive) { Call(target=stateDebugLive) { Var(name=state) } }
        Let(name=wRaw) { Call(target=uiWidth) { Var(name=handle) } }
        Let(name=hRaw) { Call(target=uiHeight) { Var(name=handle) } }
        Let(name=w) { Call(target=stabilizeSize) { Var(name=wRaw) Var(name=lastW) Lit(value=960) } }
        Let(name=h) { Call(target=stabilizeSize) { Var(name=hRaw) Var(name=lastH) Lit(value=640) } }
        If {
          Eq { Var(name=debugLive) Lit(value=true) }
          Block {
            Call(target=traceSceneFrame) { Var(name=debugLive) Var(name=w) Var(name=h) Var(name=query) Var(name=statusLine) Var(name=focused) Var(name=dropdownOpen) Var(name=radarOpen) Var(name=submitFlash) }
            Lit(value=0)
          }
          Block { Lit(value=0) }
        }
        Call(target=render) { Var(name=handle) Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=radarTick) Var(name=radarImageRgba) Var(name=netKind) Var(name=w) Var(name=h) Var(name=submitFlash) Lit(value=true) }
        Return { Lit(value=0) }
      }
    }
  }

  Let(name=appUpdate) {
    Fn(params=state,eventType,eventKey,eventText,eventX,eventY,windowWidthRaw,windowHeightRaw) {
      Block {
        Let(name=query) { Call(target=stateQuery) { Var(name=state) } }
        Let(name=focused) { Call(target=stateFocused) { Var(name=state) } }
        Let(name=dropdownOpen) { Call(target=stateDropdownOpen) { Var(name=state) } }
        Let(name=geoBody) { Call(target=stateGeoBody) { Var(name=state) } }
        Let(name=selectedLabel) { Call(target=stateSelectedLabel) { Var(name=state) } }
        Let(name=selectedLat) { Call(target=stateSelectedLat) { Var(name=state) } }
        Let(name=selectedLon) { Call(target=stateSelectedLon) { Var(name=state) } }
        Let(name=forecastBody) { Call(target=stateForecastBody) { Var(name=state) } }
        Let(name=statusLine) { Call(target=stateStatusLine) { Var(name=state) } }
        Let(name=radarOpen) { Call(target=stateRadarOpen) { Var(name=state) } }
        Let(name=radarTick) { Call(target=stateRadarTick) { Var(name=state) } }
        Let(name=radarImageRgba) { Call(target=stateRadarImageRgba) { Var(name=state) } }
        Let(name=lastW) { Call(target=stateLastW) { Var(name=state) } }
        Let(name=lastH) { Call(target=stateLastH) { Var(name=state) } }
        Let(name=submitFlash) { Call(target=stateSubmitFlash) { Var(name=state) } }
        Let(name=blinkTick) { Call(target=stateBlinkTick) { Var(name=state) } }
        Let(name=netKind) { Call(target=stateNetKind) { Var(name=state) } }
        Let(name=netState) { Call(target=stateNetState) { Var(name=state) } }
        Let(name=netTicks) { Call(target=stateNetTicks) { Var(name=state) } }
        Let(name=debugLive) { Call(target=stateDebugLive) { Var(name=state) } }
        Let(name=w) { Call(target=stabilizeSize) { Var(name=windowWidthRaw) Var(name=lastW) Lit(value=960) } }
        Let(name=h) { Call(target=stabilizeSize) { Var(name=windowHeightRaw) Var(name=lastH) Lit(value=640) } }
            Let(name=radarXDebug) { Add { Var(name=w) Lit(value=-178) } }
            Let(name=entryWDebug) { Add { Var(name=radarXDebug) Lit(value=-70) } }
            Let(name=submitXDebug) { Add { Lit(value=52) Add { Var(name=entryWDebug) Lit(value=-42) } } }
        Let(name=nextFlash) { Lit(value=0) }
        Let(name=nextBlink) { Lit(value=0) }
        Let(name=nextRadarTick) { Var(name=radarTick) }
        If {
          Eq { Var(name=eventType) Lit(value="none") }
          Block {
            If {
              Eq { Var(name=netKind) Lit(value="geo_start") }
              Block {
                Let(name=reqState) { Call(target=startGeoRequest) { Var(name=query) } }
                Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=submitFlash) Var(name=blinkTick) Lit(value="geo") Var(name=reqState) Lit(value=0) Var(name=debugLive) } }
              }
              Block {
                If {
                  Eq { Var(name=netKind) Lit(value="forecast_start") }
                  Block {
                    Let(name=reqState) { Call(target=startForecastRequest) { Var(name=selectedLat) Var(name=selectedLon) } }
                    Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=submitFlash) Var(name=blinkTick) Lit(value="forecast") Var(name=reqState) Lit(value=0) Var(name=debugLive) } }
                  }
                  Block {
                    If {
                      Eq { Var(name=netKind) Lit(value="radar_meta_start") }
                      Block {
                        Let(name=radarMetaReqState) { Call(target=startRadarMetaRequest) { Lit(value=0) } }
                        Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Loading radar...") Lit(value=true) Var(name=nextRadarTick) Lit(value="") Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="radar_meta") Var(name=radarMetaReqState) Lit(value=0) Var(name=debugLive) } }
                      }
                      Block {
                        If {
                          Eq { Var(name=netKind) Lit(value="radar_frame_start") }
                          Block {
                            Let(name=radarReqState) { Call(target=startRadarFrameRequest) { Var(name=geoBody) Var(name=selectedLat) Var(name=selectedLon) } }
                            Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Loading radar image...") Var(name=radarOpen) Var(name=nextRadarTick) Lit(value="") Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="radar_frame") Var(name=radarReqState) Lit(value=0) Var(name=debugLive) } }
                          }
                          Block {
                            If {
                              Eq { Var(name=netKind) Lit(value="") }
                              Block { Lit(value=0) }
                              Block {
                                If {
                                  Call(target=intLt) { Var(name=netTicks) Lit(value=5) }
                                  Block { Return { Call(target=stateUpdatePolling) { Var(name=state) Var(name=w) Var(name=h) Var(name=netState) Add { Var(name=netTicks) Lit(value=1) } } } }
                                  Block { Lit(value=0) }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
          Block { Lit(value=0) }
        }
        Let(name=netStateNow) {
          If {
            Eq { Var(name=netKind) Lit(value="") }
            Block { Var(name=netState) }
            Block {
              If {
                Eq { Var(name=netKind) Lit(value="geo_start") }
                Block { Var(name=netState) }
                Block {
                  If {
                    Eq { Var(name=netKind) Lit(value="forecast_start") }
                    Block { Var(name=netState) }
                    Block {
                      If {
                        Eq { Var(name=netKind) Lit(value="radar_meta_start") }
                        Block { Var(name=netState) }
                        Block {
                          If {
                            Eq { Var(name=netKind) Lit(value="radar_frame_start") }
                            Block { Var(name=netState) }
                            Block { Call(target=httpRequestPoll) { Var(name=netState) } }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
        Let(name=netTicksNow) {
          If {
            Eq { Var(name=netKind) Lit(value="") }
            Block { Lit(value=0) }
            Block { Lit(value=0) }
          }
        }

        If {
          Call(target=intLt) { Lit(value=900) Var(name=netTicksNow) }
          Block {
            If {
              Eq { Var(name=netKind) Lit(value="") }
              Block { Lit(value=0) }
              Block {
                Call(target=sys.net.asyncCancel) { Call(target=httpRequestOp) { Var(name=netStateNow) } }
                Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Request timed out.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
              }
            }
          }
          Block { Lit(value=0) }
        }

        If {
          Eq { Var(name=netKind) Lit(value="geo") }
          Block {
            If {
              Call(target=httpRequestFailed) { Var(name=netStateNow) }
              Block { Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) StrConcat { Lit(value="Geocode failed: ") Call(target=httpErrorDisplay) { Call(target=httpRequestError) { Var(name=netStateNow) } } } Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
              Block {
                If {
                  Call(target=httpRequestDone) { Var(name=netStateNow) }
                  Block {
                    Let(name=geo) { Call(target=httpResponseBodyText) { Var(name=netStateNow) } }
                    Call(target=traceNetLine) { Var(name=debugLive) Lit(value="geo.response") ToString { Call(target=strLen) { Var(name=geo) } } ToString { Call(target=contains) { Var(name=geo) Lit(value="\"results\":") } } }
                    Let(name=label1) { Call(target=geoLabelAt) { Var(name=geo) Lit(value=1) } }
                    Let(name=label2) { Call(target=geoLabelAt) { Var(name=geo) Lit(value=2) } }
                    If {
                      Eq { Var(name=geo) Lit(value="") }
                      Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Network request failed (empty response).") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                      Block { Lit(value=0) }
                    }
                    If {
                      Eq { Var(name=label1) Lit(value="") }
                      Block {
                        If {
                          Call(target=contains) { Var(name=geo) Lit(value="\"results\":[]") }
                          Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="No geocode match found.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                          Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Unexpected geocode response.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                        }
                      }
                      Block {
                        If {
                          Eq { Var(name=label2) Lit(value="") }
                          Block { Return { Call(target=selectGeoAndState) { Var(name=query) Var(name=geo) Lit(value=1) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=debugLive) } } }
                          Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=true) Var(name=geo) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Multiple matches. Choose a city.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                        }
                      }
                    }
                  }
                  Block { Lit(value=0) }
                }
              }
            }
          }
          Block {
            If {
              Eq { Var(name=netKind) Lit(value="forecast") }
              Block {
                If {
                  Call(target=httpRequestFailed) { Var(name=netStateNow) }
                  Block { Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Lit(value="") StrConcat { Lit(value="Forecast failed: ") Call(target=httpErrorDisplay) { Call(target=httpRequestError) { Var(name=netStateNow) } } } Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                  Block {
                    If {
                      Call(target=httpRequestDone) { Var(name=netStateNow) }
                      Block {
                        Let(name=forecast) { Call(target=httpResponseBodyText) { Var(name=netStateNow) } }
                        Call(target=traceNetLine) { Var(name=debugLive) Lit(value="forecast.response") ToString { Call(target=strLen) { Var(name=forecast) } } ToString { Call(target=contains) { Var(name=forecast) Lit(value="\"current\":{") } } }
                        Let(name=forecastSummary) { Call(target=encodeForecastSummary) { Var(name=forecast) } }
                        Let(name=statusOut) {
                          If {
                            Eq { Var(name=forecast) Lit(value="") }
                            Block { StrConcat { Lit(value="Loaded ") StrConcat { Var(name=selectedLabel) Lit(value="; forecast fetch failed.") } } }
                            Block { StrConcat { Lit(value="Loaded weather for ") Var(name=selectedLabel) } }
                          }
                        }
                        Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Lit(value=false) Lit(value="") Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastSummary) Var(name=statusOut) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Lit(value=0) Lit(value=0) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
                      }
                      Block { Lit(value=0) }
                    }
                  }
                }
              }
              Block {
                If {
                  Eq { Var(name=netKind) Lit(value="radar_meta") }
                  Block {
                    If {
                      Call(target=httpRequestFailed) { Var(name=netStateNow) }
                      Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) StrConcat { Lit(value="Radar failed: ") Call(target=httpErrorDisplay) { Call(target=httpRequestError) { Var(name=netStateNow) } } } Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                      Block {
                        If {
                          Call(target=httpRequestDone) { Var(name=netStateNow) }
                          Block {
                            Let(name=metaBody) { Call(target=httpResponseBodyText) { Var(name=netStateNow) } }
                            Let(name=tilePath) { Call(target=rainViewerTilePath) { Var(name=metaBody) Var(name=selectedLat) Var(name=selectedLon) } }
                            If {
                              Eq { Var(name=tilePath) Lit(value="") }
                              Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Radar metadata unavailable.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                              Block {
                                Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=metaBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Loading radar image...") Var(name=radarOpen) Var(name=nextRadarTick) Lit(value="") Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="radar_frame_start") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
                              }
                            }
                          }
                          Block { Lit(value=0) }
                        }
                      }
                    }
                  }
                  Block {
                    If {
                      Eq { Var(name=netKind) Lit(value="radar_frame") }
                      Block {
                        If {
                          Call(target=httpRequestFailed) { Var(name=netStateNow) }
                          Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) StrConcat { Lit(value="Radar failed: ") Call(target=httpErrorDisplay) { Call(target=httpRequestError) { Var(name=netStateNow) } } } Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                          Block {
                            If {
                              Call(target=httpRequestDone) { Var(name=netStateNow) }
                              Block {
                                Let(name=responseBytes) { Call(target=httpRequestResponseBytes) { Var(name=netStateNow) } }
                                Let(name=bodyBytes) { Call(target=httpResponseBodyBytes) { Var(name=responseBytes) } }
                                Let(name=decodedRgba) { Call(target=decodeToRgbaBase64) { Var(name=bodyBytes) Lit(value="image/png") } }
                                Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Radar loaded.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=decodedRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
                              }
                              Block { Lit(value=0) }
                            }
                          }
                        }
                      }
                      Block { Lit(value=0) }
                    }
                  }
                }
              }
            }
          }
        }

        Lit(value=0)

        If {
          Eq { Var(name=eventType) Lit(value="none") }
          Block {
            If {
              Eq { Var(name=netKind) Lit(value="") }
              Block { Lit(value=0) }
              Block { Return { Call(target=stateUpdatePolling) { Var(name=state) Var(name=w) Var(name=h) Var(name=netStateNow) Var(name=netTicksNow) } } }
            }
            If {
              Eq { Var(name=netKind) Lit(value="") }
              Block {
                If {
                  Eq { Var(name=w) Var(name=lastW) }
                  Block {
                    If {
                      Eq { Var(name=h) Var(name=lastH) }
                      Block { Return { Var(name=state) } }
                      Block { Lit(value=0) }
                    }
                  }
                  Block { Lit(value=0) }
                }
              }
              Block { Lit(value=0) }
            }
          }
          Block { Lit(value=0) }
        }

        If {
          Eq { Var(name=eventType) Lit(value="click") }
          Block {
            Let(name=radarX) { Add { Var(name=w) Lit(value=-178) } }
            Let(name=entryW) { Add { Var(name=radarX) Lit(value=-70) } }
            Let(name=submitX) { Add { Lit(value=52) Add { Var(name=entryW) Lit(value=-42) } } }
            Let(name=inputHit) { Call(target=pointInRect) { Var(name=eventX) Var(name=eventY) Lit(value=52) Lit(value=94) Var(name=entryW) Lit(value=48) } }
            Let(name=submitHit) { Call(target=pointInRect) { Var(name=eventX) Var(name=eventY) Var(name=submitX) Lit(value=100) Lit(value=36) Lit(value=36) } }
            Let(name=radarHit) { Call(target=pointInRect) { Var(name=eventX) Var(name=eventY) Var(name=radarX) Lit(value=46) Lit(value=126) Lit(value=34) } }
            Let(name=row1Hit) { Call(target=pointInRect) { Var(name=eventX) Var(name=eventY) Lit(value=52) Lit(value=148) Var(name=entryW) Lit(value=34) } }
            Let(name=row2Hit) { Call(target=pointInRect) { Var(name=eventX) Var(name=eventY) Lit(value=52) Lit(value=182) Var(name=entryW) Lit(value=34) } }
            Let(name=row3Hit) { Call(target=pointInRect) { Var(name=eventX) Var(name=eventY) Lit(value=52) Lit(value=216) Var(name=entryW) Lit(value=34) } }
            If {
              Eq { Var(name=dropdownOpen) Lit(value=true) }
              Block {
                If { Eq { Var(name=row1Hit) Lit(value=true) } Block { Return { Call(target=selectGeoAndState) { Var(name=query) Var(name=geoBody) Lit(value=1) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=debugLive) } } } Block { Lit(value=0) } }
                If { Eq { Var(name=row2Hit) Lit(value=true) } Block { Return { Call(target=selectGeoAndState) { Var(name=query) Var(name=geoBody) Lit(value=2) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=debugLive) } } } Block { Lit(value=0) } }
                If { Eq { Var(name=row3Hit) Lit(value=true) } Block { Return { Call(target=selectGeoAndState) { Var(name=query) Var(name=geoBody) Lit(value=3) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=debugLive) } } } Block { Lit(value=0) } }
                Lit(value=0)
              }
              Block { Lit(value=0) }
            }
            If {
              Eq { Var(name=submitHit) Lit(value=true) }
              Block {
                Call(target=traceNetLine) { Var(name=debugLive) Lit(value="submit.click") Var(name=query) ToString { Call(target=strLen) { Var(name=query) } } }
                If {
                  Eq { Var(name=netKind) Lit(value="") }
                  Block { Return { Call(target=submitQueryAndState) { Var(name=query) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=debugLive) } } }
                  Block {
                    Call(target=traceNetLine) { Var(name=debugLive) Lit(value="submit.skip.loading") Var(name=netKind) ToString { Var(name=netTicksNow) } }
                    Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } }
                  }
                }
              }
              Block { Lit(value=0) }
            }
            If {
              Eq { Var(name=radarHit) Lit(value=true) }
              Block {
                If {
                  Eq { Var(name=selectedLabel) Lit(value="") }
                  Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Load weather first, then open radar.") Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                  Block {
                    If {
                      Eq { Var(name=radarOpen) Lit(value=true) }
                      Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Radar closed.") Lit(value=false) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                      Block {
                        If {
                          Eq { Var(name=netKind) Lit(value="") }
                          Block {
                            If {
                              Eq { Var(name=radarImageRgba) Lit(value="") }
                              Block {
                                Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Loading radar...") Lit(value=true) Var(name=nextRadarTick) Lit(value="") Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="radar_meta_start") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } }
                              }
                              Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Radar opened.") Lit(value=true) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Lit(value="") Call(target=emptyNode) { Lit(value=0) } Lit(value=0) Var(name=debugLive) } } }
                            }
                          }
                          Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Lit(value="Please wait for the current request to finish.") Lit(value=true) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                        }
                      }
                    }
                  }
                }
              }
              Block { Lit(value=0) }
            }
            If {
              Eq { Var(name=inputHit) Lit(value=true) }
              Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=true) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Lit(value=0) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
              Block { Return { Call(target=weatherState) { Var(name=query) Lit(value=false) Lit(value=false) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
            }
          }
          Block {
            If {
              Eq { Var(name=eventType) Lit(value="key") }
              Block {
                If {
                  Eq { Var(name=focused) Lit(value=true) }
                  Block {
                    If {
                      Call(target=isBackKey) { Var(name=eventKey) }
                      Block { Return { Call(target=weatherState) { Call(target=weatherRemoveLastChar) { Var(name=query) } Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Lit(value=0) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                      Block {
                        If {
                          Call(target=isEnterEvent) { Var(name=eventKey) Var(name=eventText) }
                          Block { Return { Call(target=submitQueryAndState) { Var(name=query) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=debugLive) } } }
                          Block {
                            Let(name=typed) { Call(target=inputCharFromEvent) { Var(name=eventKey) Var(name=eventText) } }
                            If {
                              Eq { Var(name=typed) Lit(value="") }
                              Block { Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Lit(value=0) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                              Block {
                                If {
                                  Call(target=isForbiddenInputChar) { Var(name=typed) }
                                  Block { Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Lit(value=0) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                                  Block { Return { Call(target=weatherState) { StrConcat { Var(name=query) Var(name=typed) } Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Lit(value=0) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                  Block { Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
                }
              }
              Block { Return { Call(target=weatherState) { Var(name=query) Var(name=focused) Var(name=dropdownOpen) Var(name=geoBody) Var(name=selectedLabel) Var(name=selectedLat) Var(name=selectedLon) Var(name=forecastBody) Var(name=statusLine) Var(name=radarOpen) Var(name=nextRadarTick) Var(name=radarImageRgba) Var(name=w) Var(name=h) Var(name=nextFlash) Var(name=blinkTick) Var(name=netKind) Var(name=netStateNow) Var(name=netTicksNow) Var(name=debugLive) } } }
            }
          }
        }
      }
    }
  }

  Let(name=start) {
    Fn(params=args) {
      Block {
        Return { Call(target=appStart) { Var(name=args) Lit(value="AiVectra Weather") Lit(value=960) Lit(value=640) } }
      }
    }
  }
}
